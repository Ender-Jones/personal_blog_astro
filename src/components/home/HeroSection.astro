---
import type { SiteData } from '../../lib/data';

type Props = {
  site: SiteData;
};

const { site } = Astro.props;
const socials = [
  ['github', site.socials.github, '@enderjones'],
  ['x', site.socials.twitter, '@enderjones'],
  ['email', site.socials.email, 'hi@...'],
].filter((item): item is [string, string, string] => Boolean(item[1]));
---

<article class="home-hero" aria-label="First impression">
  <img class="home-hero__photo" src={site.avatar} alt="" loading="eager" />
  <div class="home-hero__shade" aria-hidden="true"></div>

  <div class="home-hero__body">
    <h1>
      <span class="home-hero__name">EnderJones</span><span class="blink-cursor" aria-hidden="true">_</span>
    </h1>
    <p class="home-hero__role">
      {site.role} in {site.location}, researching <b>affective computing</b> and
      <b> multi-modal physiological signals</b>.
    </p>

    <nav class="home-hero__links" aria-label="Primary contact links">
      {
        socials.map(([label, href, value]) => (
          <a href={href}>
            <span>{label}</span>
            <small>{value}</small>
          </a>
        ))
      }
    </nav>
  </div>
</article>

<style>
  .home-hero {
    position: relative;
    min-height: 340px;
    overflow: hidden;
    border: 1px solid rgba(244, 114, 182, 0.18);
    border-radius: var(--r-lg);
    background: var(--surface);
    box-shadow:
      0 0 28px rgba(244, 114, 182, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }

  .home-hero__photo,
  .home-hero__shade {
    position: absolute;
    inset: 0;
  }

  .home-hero__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    filter: brightness(0.3) saturate(0.45);
  }

  .home-hero__shade {
    background:
      linear-gradient(180deg, rgba(7, 9, 18, 0.4), transparent 60%),
      linear-gradient(180deg, rgba(7, 9, 18, 0.08), rgba(7, 9, 18, 0.54) 46%, rgba(7, 9, 18, 0.98) 94%);
  }

  .home-hero__body {
    position: absolute;
    z-index: 2;
    right: clamp(var(--s-6), 5vw, var(--s-10));
    bottom: clamp(var(--s-6), 5vw, var(--s-8));
    left: clamp(var(--s-6), 5vw, var(--s-10));
  }

  .home-hero h1 {
    margin: 0;
    font-size: clamp(36px, 3.8vw, 48px);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 0.92;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.45);
  }

  .home-hero__name {
    color: var(--accent-pink);
    filter: drop-shadow(0 0 24px rgba(244, 114, 182, 0.22));
  }

  .home-hero h1 .blink-cursor {
    color: var(--accent-pink);
  }

  .home-hero__role {
    max-width: 620px;
    margin: var(--s-5) 0 0;
    color: #e8eaed;
    font-size: 16px;
    font-weight: 300;
    line-height: 1.55;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.5);
  }

  .home-hero__role b {
    color: var(--accent-teal);
    font-weight: 500;
  }

  .home-hero__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    margin-top: var(--s-6);
  }

  .home-hero__links a {
    display: inline-flex;
    align-items: baseline;
    gap: var(--s-2);
    padding: 4px 11px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    background: rgba(7, 8, 9, 0.55);
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 11px;
    backdrop-filter: blur(8px);
  }

  .home-hero__links small {
    color: var(--accent-blue);
    font-size: 11px;
  }

  @media (max-width: 720px) {
    .home-hero {
      min-height: 380px;
    }

    .home-hero h1 {
      font-size: clamp(38px, 12vw, 50px);
    }

    .home-hero__role {
      font-size: 15px;
    }
  }
</style>
