---
import type { SiteData } from '../../lib/data';

type Props = {
  site: SiteData;
};

const { site } = Astro.props;
const socials = [
  ['github', site.socials.github, '@enderjones'],
  ['x', site.socials.twitter, '@enderjones'],
  ['email', site.socials.email, 'hi@...'],
].filter((item): item is [string, string, string] => Boolean(item[1]));
---

<article class="home-hero" aria-label="First impression">
  <img class="home-hero__photo" src={site.avatar} alt="" loading="eager" />
  <div class="home-hero__shade" aria-hidden="true"></div>
  <div class="home-hero__grid" aria-hidden="true"></div>

  <div class="home-hero__mark">
    <span></span>
    <p>The author</p>
  </div>

  <p class="home-hero__coord">35°41'N · 139°41'E</p>

  <div class="home-hero__body">
    <h1>
      <span>Ender</span>Jones<span class="blink-cursor" aria-hidden="true">_</span>
    </h1>
    <p class="home-hero__role">
      {site.role} in {site.location}, researching <b>affective computing</b> and
      <b> multi-modal physiological signals</b>.
    </p>
    <p class="home-hero__note">A research notebook, writing archive, and append-only worklog.</p>

    <div class="home-hero__line" aria-hidden="true"></div>

    <nav class="home-hero__links" aria-label="Primary contact links">
      {
        socials.map(([label, href, value]) => (
          <a href={href}>
            <span>{label}</span>
            <small>{value}</small>
          </a>
        ))
      }
    </nav>
  </div>
</article>

<style>
  .home-hero {
    position: relative;
    min-height: 528px;
    overflow: hidden;
    border: 1px solid rgba(244, 114, 182, 0.18);
    border-radius: var(--r-lg);
    background: var(--surface);
    box-shadow:
      0 0 28px rgba(244, 114, 182, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }

  .home-hero__photo,
  .home-hero__shade,
  .home-hero__grid {
    position: absolute;
    inset: 0;
  }

  .home-hero__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    filter: brightness(0.78) saturate(0.95);
  }

  .home-hero__shade {
    background:
      linear-gradient(180deg, rgba(7, 8, 9, 0.12), rgba(7, 8, 9, 0.54) 46%, rgba(7, 8, 9, 0.97) 94%),
      radial-gradient(760px 520px at 22% 100%, rgba(244, 114, 182, 0.14), transparent 62%),
      radial-gradient(640px 420px at 86% 20%, rgba(56, 189, 248, 0.08), transparent 60%);
  }

  .home-hero__grid {
    opacity: 0.48;
    background-image:
      linear-gradient(to right, rgba(148, 163, 184, 0.025) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(148, 163, 184, 0.025) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  .home-hero__mark,
  .home-hero__coord,
  .home-hero__body {
    position: absolute;
    z-index: 2;
  }

  .home-hero__mark {
    top: var(--s-6);
    left: var(--s-6);
    display: flex;
    align-items: center;
    gap: var(--s-3);
  }

  .home-hero__mark span {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--accent-pink);
    box-shadow: 0 0 10px var(--accent-pink);
  }

  .home-hero__mark p,
  .home-hero__coord {
    margin: 0;
    color: rgba(255, 255, 255, 0.62);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.45);
  }

  .home-hero__coord {
    top: var(--s-6);
    right: clamp(var(--s-6), 4vw, var(--s-10));
    text-transform: none;
  }

  .home-hero__body {
    right: clamp(var(--s-6), 5vw, var(--s-10));
    bottom: clamp(var(--s-6), 5vw, var(--s-8));
    left: clamp(var(--s-6), 5vw, var(--s-10));
  }

  .home-hero h1 {
    margin: 0;
    color: #fff;
    font-size: clamp(54px, 7vw, 84px);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 0.92;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.45);
  }

  .home-hero h1 > span:first-child {
    color: transparent;
    background: linear-gradient(135deg, #fff 0%, var(--accent-pink) 62%, var(--accent-blue) 100%);
    background-clip: text;
    filter: drop-shadow(0 0 24px rgba(244, 114, 182, 0.22));
  }

  .home-hero__role {
    max-width: 620px;
    margin: var(--s-5) 0 0;
    color: #e8eaed;
    font-size: 16px;
    font-weight: 300;
    line-height: 1.55;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.5);
  }

  .home-hero__role b {
    color: var(--accent-blue);
    font-weight: 500;
  }

  .home-hero__role b:first-of-type {
    color: var(--accent-pink);
  }

  .home-hero__note {
    max-width: 560px;
    margin: var(--s-2) 0 0;
    color: rgba(255, 255, 255, 0.72);
    font-family: var(--font-serif);
    font-size: 14px;
    font-style: italic;
  }

  .home-hero__line {
    height: 1px;
    margin-top: var(--s-6);
    background: linear-gradient(90deg, rgba(244, 114, 182, 0.5), rgba(56, 189, 248, 0.3) 40%, transparent 75%);
  }

  .home-hero__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    margin-top: var(--s-4);
  }

  .home-hero__links a {
    display: inline-flex;
    align-items: baseline;
    gap: var(--s-2);
    padding: 4px 11px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    background: rgba(7, 8, 9, 0.55);
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 11px;
    backdrop-filter: blur(8px);
  }

  .home-hero__links small {
    color: var(--accent-blue);
    font-size: 11px;
  }

  @media (max-width: 720px) {
    .home-hero {
      min-height: 560px;
    }

    .home-hero__coord {
      display: none;
    }

    .home-hero h1 {
      font-size: clamp(48px, 15vw, 68px);
    }

    .home-hero__role {
      font-size: 15px;
    }
  }
</style>
