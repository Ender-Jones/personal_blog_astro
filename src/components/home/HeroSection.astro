---
import SectionLabel from '../ui/SectionLabel.astro';
import type { SiteData } from '../../lib/data';

type Props = {
  site: SiteData;
};

const { site } = Astro.props;
const socials = [
  ['GitHub', site.socials.github],
  ['X', site.socials.twitter],
  ['Email', site.socials.email],
].filter((item): item is [string, string] => Boolean(item[1]));
---

<section class="home-hero" aria-label="First impression">
  <div class="home-hero__copy">
    <SectionLabel tone="pink">Research notebook · personal archive</SectionLabel>
    <h1>{site.name}<span class="blink-cursor" aria-hidden="true">_</span></h1>
    <p class="home-hero__role">{site.role} in {site.location}</p>
    <p class="home-hero__summary">
      Affective computing, multimodal physiological signals, and the work log behind the research.
    </p>
    <nav class="home-hero__links" aria-label="Primary contact links">
      {socials.map(([label, href]) => <a href={href}>{label}</a>)}
    </nav>
  </div>

  <div class="home-hero__portrait" aria-hidden="true">
    <img src={site.avatar} alt="" loading="eager" />
  </div>
</section>

<style>
  .home-hero {
    position: relative;
    min-height: 500px;
    overflow: hidden;
    border: 1px solid rgba(56, 189, 248, 0.22);
    border-radius: var(--r-xl);
    background:
      linear-gradient(135deg, rgba(7, 26, 47, 0.95), rgba(10, 13, 20, 0.9) 58%),
      linear-gradient(to right, rgba(67, 200, 255, 0.08) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(67, 200, 255, 0.06) 1px, transparent 1px);
    background-size: auto, 42px 42px, 42px 42px;
  }

  .home-hero__copy {
    position: relative;
    z-index: 1;
    max-width: 660px;
    padding: clamp(var(--s-8), 6vw, var(--s-12));
  }

  .home-hero h1 {
    margin: var(--s-6) 0 var(--s-4);
    color: #fff;
    font-size: clamp(58px, 8vw, 104px);
    line-height: 0.92;
  }

  .home-hero__role,
  .home-hero__summary {
    margin: 0;
    color: #dfe4ea;
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.55;
  }

  .home-hero__summary {
    max-width: 600px;
    margin-top: var(--s-3);
    color: var(--text-muted);
    font-size: 17px;
  }

  .home-hero__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-3);
    margin-top: var(--s-10);
    padding-top: var(--s-5);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .home-hero__links a {
    color: var(--accent-blue);
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .home-hero__portrait {
    position: absolute;
    right: clamp(var(--s-6), 5vw, var(--s-12));
    bottom: var(--s-10);
    z-index: 1;
    width: clamp(86px, 9vw, 132px);
    overflow: hidden;
    border: 1px solid rgba(56, 189, 248, 0.34);
    border-radius: var(--r-lg);
    background: var(--surface);
    box-shadow: 0 28px 70px rgba(0, 0, 0, 0.38);
  }

  .home-hero__portrait img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    filter: brightness(0.92) saturate(0.95);
  }

  @media (max-width: 820px) {
    .home-hero {
      min-height: 0;
    }

    .home-hero__copy {
      padding: var(--s-6);
      padding-bottom: 148px;
    }

    .home-hero h1 {
      font-size: clamp(46px, 14vw, 68px);
    }

    .home-hero__portrait {
      right: var(--s-6);
      bottom: var(--s-8);
      width: 84px;
    }
  }
</style>
