---
import SectionLabel from '../ui/SectionLabel.astro';
import type { CurrentThread } from '../../lib/parseWorklog';
import { formatDate, worklogHref } from '../../lib/content';

type Props = {
  thread: CurrentThread;
};

const { thread } = Astro.props;
const hasThread = thread.state !== 'collapsed';
const updatedAt = 'updatedAt' in thread ? thread.updatedAt : undefined;
const href = 'worklog' in thread && thread.worklog ? worklogHref(thread.worklog) : '/worklog/';
---

<article class="thread-compact">
  <div>
    <div class="thread-compact__top">
      <SectionLabel tone="pink">Current Thread</SectionLabel>
      <a href={href}>open worklog</a>
    </div>
    <h2>{hasThread ? thread.summary : 'No public thread set yet.'}</h2>
  </div>
  <p>{updatedAt ? `updated ${formatDate(updatedAt)}` : 'add a public summary to surface activity here'}</p>
</article>

<style>
  .thread-compact {
    display: flex;
    min-height: 238px;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--s-6);
    padding: var(--s-6);
    border: 1px solid rgba(244, 114, 182, 0.18);
    border-radius: var(--r-xl);
    background:
      linear-gradient(180deg, rgba(244, 114, 182, 0.045), transparent),
      rgba(18, 11, 20, 0.88);
  }

  .thread-compact__top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s-4);
  }

  .thread-compact__top a,
  .thread-compact p {
    margin: 0;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .thread-compact__top a {
    color: var(--accent-blue);
  }

  .thread-compact h2 {
    margin: var(--s-6) 0 0;
    overflow: hidden;
    color: #fff;
    display: -webkit-box;
    font-family: var(--font-serif);
    font-size: clamp(24px, 2.4vw, 30px);
    font-weight: 400;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    line-height: 1.24;
  }

  @media (max-width: 560px) {
    .thread-compact {
      min-height: 0;
    }

    .thread-compact__top {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--s-2);
    }
  }
</style>
