---
import { worklogHref } from '../../lib/content';
import type { CurrentThread } from '../../lib/parseWorklog';

type Props = {
  thread: CurrentThread;
};

const { thread } = Astro.props;
const hasThread = thread.state !== 'collapsed';
const href = 'worklog' in thread && thread.worklog ? worklogHref(thread.worklog) : '/worklog/';
const headline = hasThread ? thread.summary : 'No public thread set yet.';
---

<article class="margins-card">
  <div class="margins-card__wash" aria-hidden="true"></div>

  <div class="margins-card__note">
    <p>{headline}</p>
  </div>

  <div class="margins-card__foot">
    <a href={href}>open worklog →</a>
  </div>
</article>

<style>
  .margins-card {
    position: relative;
    display: flex;
    min-height: 0;
    overflow: hidden;
    flex-direction: column;
    justify-content: space-between;
    gap: 14px;
    padding: 20px 24px;
    border: 1px solid rgba(56, 189, 248, 0.22);
    border-radius: var(--r-lg);
    background: var(--surface);
    box-shadow:
      0 0 28px rgba(56, 189, 248, 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .margins-card__wash {
    position: absolute;
    inset: 0;
    background: radial-gradient(420px 220px at 0% 0%, rgba(56, 189, 248, 0.08), transparent 60%);
    pointer-events: none;
  }

  .margins-card > *:not(.margins-card__wash) {
    position: relative;
  }

  .margins-card__note p {
    max-width: 380px;
    margin: 0;
    color: #fff;
    font-family: var(--font-serif);
    font-size: clamp(17px, 1.35vw, 19px);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.003em;
    line-height: 1.35;
    text-wrap: pretty;
  }

  .margins-card__foot {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--s-4);
    padding-top: var(--s-2);
    border-top: 1px dashed rgba(255, 255, 255, 0.07);
    font-family: var(--font-mono);
    font-size: 10.5px;
  }
  .margins-card__foot a {
    flex-shrink: 0;
    color: var(--accent-blue);
  }
</style>
