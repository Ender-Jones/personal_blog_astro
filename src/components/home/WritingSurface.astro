---
import SectionLabel from '../ui/SectionLabel.astro';
import SectionMarker from '../ui/SectionMarker.astro';
import { formatPostDate, getReadingStats, postHref, type PostEntry } from '../../lib/content';

type Props = {
  posts: PostEntry[];
};

const { posts } = Astro.props;
const initialIndex = 0;
const previewPosts = posts.map((post) => {
  const stats = getReadingStats(post.body);

  return {
    id: post.id,
    href: postHref(post),
    title: post.data.title,
    date: formatPostDate(post.data.date),
    dateShort: new Intl.DateTimeFormat('en', {
      timeZone: 'Asia/Tokyo',
      month: 'short',
      day: '2-digit',
    }).format(post.data.date),
    year: String(post.data.date.getFullYear()),
    tags: post.data.tags,
    readTime: `${stats.minutes} min`,
    excerpt: post.data.description ?? '',
    bodyPreview: getPostSnippet(post.body, post.data.description ?? ''),
    img: post.data.image ?? '',
    imageAlt: post.data.image_alt ?? '',
    imageFocus: post.data.image_focus,
    pinned: post.data.pinned,
    language: post.data.language,
    languageLabel: post.data.language === 'zh' ? 'ZH' : 'EN',
  };
});
const initialPost = previewPosts[initialIndex];
const initialSlots = getRailSlots(initialIndex);
const previewJson = JSON.stringify(previewPosts).replace(/</g, '\\u003c');

function getRailSlots(index: number) {
  if (previewPosts.length === 0) return [];

  return [
    { slot: 'prev', post: previewPosts[mod(index - 1, previewPosts.length)] },
    { slot: 'active', post: previewPosts[mod(index, previewPosts.length)] },
    { slot: 'next', post: previewPosts[mod(index + 1, previewPosts.length)] },
  ];
}

function mod(index: number, length: number) {
  return ((index % length) + length) % length;
}

function getPostSnippet(markdown = '', fallback = '') {
  const normalizedFallback = normalizeText(fallback);
  const paragraphs = markdown
    .replace(/```[\s\S]*?```/g, ' ')
    .replace(/<style[\s\S]*?<\/style>/gi, ' ')
    .replace(/<script[\s\S]*?<\/script>/gi, ' ')
    .replace(/<br\s*\/?>/gi, ' ')
    .replace(/<\/p>/gi, '\n\n')
    .replace(/<[^>]+>/g, ' ')
    .split(/\n{2,}/)
    .map((block) => normalizeText(block))
    .filter(Boolean)
    .filter((text) => !/^import\s/.test(text))
    .filter((text) => !text.startsWith('<'))
    .filter((text) => !/[{};]/.test(text));

  const paragraph =
    paragraphs.find((text) => text.length > 48 && text !== normalizedFallback) ??
    paragraphs.find((text) => text !== normalizedFallback) ??
    '';

  return truncateText(paragraph, 220);
}

function normalizeText(value = '') {
  return value
    .replace(/!\[[^\]]*]\([^)]*\)/g, ' ')
    .replace(/\[([^\]]+)]\([^)]*\)/g, '$1')
    .replace(/^#{1,6}\s+/gm, '')
    .replace(/^[-*+]\s+/gm, '')
    .replace(/[*_`>#~|{}[\]()]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

function truncateText(text: string, limit: number) {
  if (text.length <= limit) return text;

  return `${text.slice(0, limit).replace(/\s+\S*$/, '')}...`;
}
---

<section class="home-writing" data-home-writing data-initial-index={initialIndex} aria-labelledby="writing-title">
  <SectionMarker number="02" name="WRITING" />

  <div class="home-writing__grid">
    <aside class="post-drum" aria-label="Post rail">
      <div class="post-drum__top">
        <SectionLabel tone="blue">↳ Post drum</SectionLabel>
        <span data-rail-count>{String(initialIndex + 1).padStart(2, '0')} / {String(posts.length).padStart(2, '0')}</span>
      </div>

      <div class="post-drum__window" data-post-drum tabindex="0" aria-label="Time ordered post selector">
        <div class="post-drum__center" aria-hidden="true">
          <span></span>
          <i></i>
          <small>now</small>
        </div>

        <ol class="post-drum__stack" data-post-drum-stack>
          {
            initialSlots.map(({ slot, post }) => (
              <li class={`post-drum__slot post-drum__slot--${slot}`}>
                <button
                  type="button"
                  data-drum-slot={slot}
                  data-index={previewPosts.findIndex((item) => item.id === post.id)}
                  aria-current={slot === 'active' ? 'true' : undefined}
                >
                  <span class="post-drum__date">
                    <b data-slot-date>{post.dateShort}</b>
                    <small data-slot-year>{post.year}</small>
                  </span>
                  <span class="post-drum__copy">
                    <strong data-slot-title>{post.title}</strong>
                    <span data-slot-tags>
                      {post.tags.slice(0, 2).map((tag) => <em>#{tag}</em>)}
                      <em>{post.languageLabel}</em>
                      <em>{post.readTime}</em>
                    </span>
                  </span>
                  <span class="post-drum__dot">●</span>
                </button>
              </li>
            ))
          }
        </ol>
      </div>

      <div class="post-drum__foot">
        <span>wheel / tap</span>
        <a href="/posts/">all writing →</a>
      </div>
    </aside>

    <article class="preview-card" data-home-preview>
      <a class="preview-card__cover" href={initialPost?.href ?? '/posts/'} data-preview-link>
        <img
          src={initialPost?.img}
          alt={initialPost?.imageAlt}
          loading="lazy"
          style={`object-position: ${initialPost?.imageFocus ?? '50% 50%'}`}
          data-preview-image
        />
        <span class="preview-card__badge" data-preview-badge>
          {initialPost?.pinned ? 'Pinned in archive' : 'Time-order preview'}
        </span>
      </a>

      <div class="preview-card__body" data-preview-body>
        <div class="preview-card__meta" data-preview-meta>
          <span>{initialPost?.date}</span>
          <span>{initialPost?.readTime}</span>
          <span>{initialPost?.languageLabel}</span>
        </div>

        <h2 id="writing-title" data-preview-title>{initialPost?.title}</h2>
        <p class="preview-card__dek" data-preview-excerpt>{initialPost?.excerpt}</p>
        <p class="preview-card__note" data-preview-note>{initialPost?.bodyPreview}</p>

        <div class="preview-card__tags" data-preview-tags>
          {initialPost?.tags.map((tag) => <em>#{tag}</em>)}
        </div>

        <div class="preview-card__foot">
          <span data-preview-slug>posts/{initialPost?.id}/</span>
          <a href={initialPost?.href ?? '/posts/'} data-preview-read>read post →</a>
        </div>
      </div>
    </article>
  </div>

  <script is:inline type="application/json" data-home-post-data set:html={previewJson}></script>
  <script is:inline>
    const roots = document.querySelectorAll('[data-home-writing]');

    for (const root of roots) {
      const dataEl = root.querySelector('[data-home-post-data]');
      const drum = root.querySelector('[data-post-drum]');
      const stack = root.querySelector('[data-post-drum-stack]');
      const slotButtons = [...root.querySelectorAll('[data-drum-slot]')];
      const count = root.querySelector('[data-rail-count]');
      const previewLink = root.querySelector('[data-preview-link]');
      const previewRead = root.querySelector('[data-preview-read]');
      const previewImage = root.querySelector('[data-preview-image]');
      const previewBadge = root.querySelector('[data-preview-badge]');
      const previewMeta = root.querySelector('[data-preview-meta]');
      const previewTags = root.querySelector('[data-preview-tags]');
      const previewBody = root.querySelector('[data-preview-body]');
      const previewTitle = root.querySelector('[data-preview-title]');
      const previewExcerpt = root.querySelector('[data-preview-excerpt]');
      const previewNote = root.querySelector('[data-preview-note]');
      const previewSlug = root.querySelector('[data-preview-slug]');
      const posts = JSON.parse(dataEl?.textContent || '[]');
      let activeIndex = Number(root.getAttribute('data-initial-index') || 0);
      let movementLocked = false;
      let touchStartY = 0;

      if (!posts.length) continue;

      function mod(index) {
        return ((index % posts.length) + posts.length) % posts.length;
      }

      function slotIndex(slot) {
        if (slot === 'prev') return mod(activeIndex - 1);
        if (slot === 'next') return mod(activeIndex + 1);
        return mod(activeIndex);
      }

      function makeChip(text) {
        const chip = document.createElement('em');
        chip.textContent = text;
        return chip;
      }

      function setText(target, text) {
        if (target) target.textContent = text || '';
      }

      function renderSlot(button) {
        const slot = button.getAttribute('data-drum-slot') || 'active';
        const index = slotIndex(slot);
        const post = posts[index];
        if (!post) return;

        button.dataset.index = String(index);
        button.setAttribute('aria-current', slot === 'active' ? 'true' : 'false');
        setText(button.querySelector('[data-slot-date]'), post.dateShort);
        setText(button.querySelector('[data-slot-year]'), post.year);
        setText(button.querySelector('[data-slot-title]'), post.title);

        const tags = button.querySelector('[data-slot-tags]');
        if (tags) {
          tags.replaceChildren(
            ...post.tags.slice(0, 2).map((tag) => makeChip(`#${tag}`)),
            makeChip(post.languageLabel),
            makeChip(post.readTime),
          );
        }
      }

      function animateDrum(direction) {
        if (!stack || direction === 'none') return;

        stack.classList.remove('is-moving-prev', 'is-moving-next');
        void stack.offsetHeight;
        stack.classList.add(direction === 'prev' ? 'is-moving-prev' : 'is-moving-next');
      }

      function renderDrum(direction = 'none') {
        slotButtons.forEach(renderSlot);
        animateDrum(direction);
      }

      function updatePreview(post) {
        if (count) count.textContent = `${String(activeIndex + 1).padStart(2, '0')} / ${String(posts.length).padStart(2, '0')}`;
        if (previewLink) previewLink.href = post.href;
        if (previewRead) previewRead.href = post.href;
        if (previewImage) {
          if (post.img) {
            previewImage.src = post.img;
            previewImage.style.display = '';
          } else {
            previewImage.removeAttribute('src');
            previewImage.style.display = 'none';
          }
          previewImage.alt = post.imageAlt || '';
          previewImage.style.objectPosition = post.imageFocus || '50% 50%';
        }
        if (previewBadge) previewBadge.textContent = post.pinned ? 'Pinned in archive' : 'Time-order preview';
        if (previewMeta) {
          previewMeta.replaceChildren(
            ...[post.date, post.readTime, post.languageLabel].map((item) => {
              const meta = document.createElement('span');
              meta.textContent = item;
              return meta;
            }),
          );
        }
        if (previewTags) {
          previewTags.replaceChildren(...post.tags.map((tag) => makeChip(`#${tag}`)));
        }
        setText(previewTitle, post.title);
        setText(previewExcerpt, post.excerpt);
        setText(previewNote, post.bodyPreview);
        setText(previewSlug, `posts/${post.id}/`);
        if (previewBody) {
          previewBody.classList.remove('is-swapping');
          void previewBody.offsetWidth;
          previewBody.classList.add('is-swapping');
        }
      }

      function setActive(index, direction = 'none') {
        activeIndex = mod(index);
        const post = posts[activeIndex];
        if (!post) return;

        renderDrum(direction);
        updatePreview(post);
      }

      function move(delta) {
        if (posts.length < 2) return;
        setActive(activeIndex + delta, delta < 0 ? 'prev' : 'next');
      }

      slotButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const slot = button.getAttribute('data-drum-slot');
          if (slot === 'prev') move(-1);
          if (slot === 'next') move(1);
        });
      });

      drum?.addEventListener(
        'wheel',
        (event) => {
          event.preventDefault();
          if (movementLocked || Math.abs(event.deltaY) < 6) return;

          movementLocked = true;
          move(event.deltaY > 0 ? 1 : -1);
          window.setTimeout(() => {
            movementLocked = false;
          }, 260);
        },
        { passive: false },
      );

      drum?.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowUp') {
          event.preventDefault();
          move(-1);
        }
        if (event.key === 'ArrowDown') {
          event.preventDefault();
          move(1);
        }
      });

      drum?.addEventListener(
        'touchstart',
        (event) => {
          touchStartY = event.touches[0]?.clientY || 0;
        },
        { passive: true },
      );

      drum?.addEventListener(
        'touchend',
        (event) => {
          const touchEndY = event.changedTouches[0]?.clientY || touchStartY;
          const delta = touchStartY - touchEndY;
          if (Math.abs(delta) > 24) move(delta > 0 ? 1 : -1);
        },
        { passive: true },
      );

      setActive(activeIndex);
    }
  </script>
</section>

<style>
  @keyframes home-preview-fade {
    from {
      opacity: 0;
      transform: translateY(6px);
      filter: blur(2px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }

  @keyframes drum-move-prev {
    from {
      transform: translateY(-18px);
    }

    to {
      transform: translateY(0);
    }
  }

  @keyframes drum-move-next {
    from {
      transform: translateY(18px);
    }

    to {
      transform: translateY(0);
    }
  }

  .home-writing {
    display: grid;
    gap: var(--s-4);
  }

  .home-writing__grid {
    --writing-panel-height: clamp(396px, 31vw, 437px);

    display: grid;
    min-height: 0;
    grid-template-columns: minmax(260px, 0.86fr) minmax(0, 1.74fr);
    gap: var(--s-4);
    align-items: stretch;
  }

  .post-drum,
  .preview-card {
    height: var(--writing-panel-height);
    min-height: 0;
    overflow: hidden;
    border-radius: var(--r-lg);
    background: var(--surface);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
    transition:
      border-color 90ms ease,
      box-shadow 90ms ease;
  }

  .post-drum {
    display: flex;
    border: 1px solid rgba(56, 189, 248, 0.18);
    flex-direction: column;
  }

  .post-drum:hover {
    border-color: rgba(56, 189, 248, 0.28);
    box-shadow:
      0 0 18px rgba(56, 189, 248, 0.07),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .post-drum__top,
  .post-drum__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-3);
    padding: 10px 16px 8px;
  }

  .post-drum__top span,
  .post-drum__foot span,
  .post-drum__foot a {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 10px;
  }

  .post-drum__foot {
    padding-top: 8px;
    padding-bottom: 10px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .post-drum__foot a,
  .preview-card__foot a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 7px 15px;
    border: 1px solid rgba(244, 114, 182, 0.46);
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(244, 114, 182, 0.24), rgba(244, 114, 182, 0.08));
    color: #fff;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    box-shadow:
      0 0 22px rgba(244, 114, 182, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.14);
  }

  .post-drum__foot a {
    border-color: rgba(56, 189, 248, 0.42);
    background: linear-gradient(135deg, rgba(56, 189, 248, 0.2), rgba(56, 189, 248, 0.07));
    box-shadow:
      0 0 18px rgba(56, 189, 248, 0.14),
      inset 0 1px 0 rgba(255, 255, 255, 0.12);
  }

  .post-drum__window {
    position: relative;
    display: flex;
    min-height: 0;
    flex: 1;
    align-items: stretch;
    padding: 4px 0;
    outline: none;
  }

  .post-drum__window:focus-visible {
    box-shadow: inset 0 0 0 1px rgba(56, 189, 248, 0.42);
  }

  .post-drum__center {
    position: absolute;
    top: 50%;
    right: 10px;
    left: 10px;
    z-index: 0;
    height: 34%;
    border: 1px solid rgba(56, 189, 248, 0.16);
    border-radius: var(--r-sm);
    background:
      linear-gradient(90deg, rgba(56, 189, 248, 0.08), rgba(56, 189, 248, 0.018)),
      rgba(255, 255, 255, 0.01);
    transform: translateY(-50%);
    pointer-events: none;
  }

  .post-drum__center span,
  .post-drum__center i,
  .post-drum__center small {
    display: none;
  }

  .post-drum__stack {
    position: relative;
    z-index: 1;
    display: grid;
    width: 100%;
    margin: 0;
    padding: 0 10px;
    grid-template-rows: 1fr 1.22fr 1fr;
    gap: 5px;
    list-style: none;
  }

  .post-drum__stack.is-moving-prev {
    animation: drum-move-prev 0.24s ease-out;
  }

  .post-drum__stack.is-moving-next {
    animation: drum-move-next 0.24s ease-out;
  }

  .post-drum__slot {
    min-height: 0;
  }

  .post-drum button {
    display: grid;
    width: 100%;
    height: 100%;
    min-height: 0;
    grid-template-columns: 48px 1fr auto;
    gap: var(--s-3);
    align-items: center;
    padding: 8px 12px;
    border: 1px solid transparent;
    border-radius: var(--r-sm);
    background: transparent;
    cursor: pointer;
    opacity: 0.86;
    text-align: left;
    transform: scale(0.975);
    transform-origin: center;
    transition:
      opacity 0.22s ease,
      transform 0.22s ease,
      background 0.22s ease,
      border-color 0.22s ease;
  }

  .post-drum button:hover {
    opacity: 0.9;
    transform: scale(0.99);
  }

  .post-drum button[aria-current='true'] {
    position: relative;
    border-color: rgba(56, 189, 248, 0.36);
    background:
      linear-gradient(90deg, rgba(56, 189, 248, 0.16), rgba(56, 189, 248, 0.035)),
      rgba(7, 8, 9, 0.82);
    box-shadow:
      0 0 18px rgba(56, 189, 248, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    opacity: 1;
    transform: scale(1);
  }

  .post-drum__date b,
  .post-drum__date small,
  .post-drum__copy em,
  .post-drum__dot {
    display: block;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 10px;
    font-style: normal;
  }

  .post-drum__date b {
    color: var(--accent-blue);
    font-size: 11px;
    font-weight: 600;
  }

  .post-drum button:not([aria-current='true']) .post-drum__date b {
    color: rgba(56, 189, 248, 0.72);
  }

  .post-drum__date small {
    margin-top: var(--s-1);
    opacity: 0.75;
  }

  .post-drum__copy {
    min-width: 0;
  }

  .post-drum__copy strong {
    display: -webkit-box;
    overflow: hidden;
    color: #fff;
    font-size: 14.5px;
    font-weight: 600;
    line-height: 1.25;
    text-wrap: pretty;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .post-drum button:not([aria-current='true']) .post-drum__copy strong {
    color: rgba(241, 243, 245, 0.84);
  }

  .post-drum__copy > span {
    display: flex;
    overflow: hidden;
    gap: 7px;
    align-items: center;
    margin-top: 6px;
  }

  .post-drum__copy em {
    flex-shrink: 0;
    padding: 1px 6px;
    border: 1px solid rgba(56, 189, 248, 0.3);
    border-radius: 3px;
    background: rgba(56, 189, 248, 0.1);
    color: #d7e5f0;
    font-size: 9px;
  }

  .post-drum button:not([aria-current='true']) .post-drum__copy em {
    color: rgba(215, 229, 240, 0.84);
  }

  .post-drum__dot {
    align-self: center;
    color: transparent;
    width: 18px;
    font-size: 11px;
    text-align: right;
  }

  .post-drum button[aria-current='true'] .post-drum__dot {
    color: var(--accent-blue);
  }

  .preview-card {
    display: grid;
    grid-template-columns: minmax(230px, 0.88fr) minmax(0, 1.12fr);
    border: 1px solid rgba(244, 114, 182, 0.22);
  }

  .preview-card:hover {
    border-color: rgba(244, 114, 182, 0.32);
    box-shadow:
      0 0 18px rgba(244, 114, 182, 0.075),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .preview-card__cover {
    position: relative;
    display: block;
    min-height: 0;
    overflow: hidden;
  }

  .preview-card__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.82) saturate(0.92);
    transform: scale(1.01);
  }

  .preview-card__cover::after {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(7, 8, 9, 0.04), rgba(7, 8, 9, 0.36)),
      radial-gradient(420px 180px at 0% 100%, rgba(244, 114, 182, 0.16), transparent 68%);
    content: '';
  }

  .preview-card__badge {
    position: absolute;
    top: var(--s-4);
    left: var(--s-4);
    z-index: 1;
    padding: 5px 12px;
    border: 1px solid rgba(244, 114, 182, 0.32);
    border-radius: 999px;
    background: rgba(7, 8, 9, 0.62);
    color: var(--accent-pink);
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.06em;
    backdrop-filter: blur(8px);
  }

  .preview-card__body {
    display: flex;
    min-width: 0;
    flex-direction: column;
    padding: 20px 24px 18px;
  }

  .preview-card__body.is-swapping {
    animation: home-preview-fade 0.36s ease-out;
  }

  .preview-card__meta,
  .preview-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
  }

  .preview-card__meta span,
  .preview-card__tags em {
    font-family: var(--font-mono);
    font-style: normal;
  }

  .preview-card__meta span {
    color: var(--text-dim);
    font-size: 10px;
    letter-spacing: 0.06em;
  }

  .preview-card__meta span:first-child {
    color: var(--accent-pink);
  }

  .preview-card h2 {
    display: -webkit-box;
    overflow: hidden;
    margin: 10px 0 0;
    color: #fff;
    font-size: clamp(23px, 2.6vw, 29px);
    font-weight: 700;
    letter-spacing: -0.018em;
    line-height: 1.12;
    text-wrap: balance;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .preview-card__dek {
    display: -webkit-box;
