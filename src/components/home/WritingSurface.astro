---
import SectionLabel from '../ui/SectionLabel.astro';
import type { PostEntry } from '../../lib/content';
import { formatDate, postHref } from '../../lib/content';

type FeaturedSource = 'selected' | 'pinned' | 'latest' | 'startHere';

type Props = {
  featured: PostEntry | null;
  posts: PostEntry[];
  source: FeaturedSource;
};

const { featured, posts, source } = Astro.props;
const sourceLabel = {
  selected: 'Selected',
  pinned: 'Start Here',
  latest: 'Latest',
  startHere: 'Start Here',
}[source];
const featuredMeta = featured
  ? [formatDate(featured.data.date), ...featured.data.tags.slice(0, 2)].join(' · ')
  : '';
---

<section class="writing-surface" aria-labelledby="writing-title">
  <div class="writing-surface__preview">
    <SectionLabel tone="pink">Featured / {sourceLabel}</SectionLabel>
    {
      featured ? (
        <a class="writing-feature" href={postHref(featured)}>
          <div class="writing-feature__copy">
            <h2 id="writing-title">{featured.data.title}</h2>
            <p class="writing-feature__meta">{featuredMeta}</p>
          </div>
          {featured.data.image && (
            <img src={featured.data.image} alt={featured.data.image_alt ?? ''} loading="lazy" />
          )}
          {featured.data.description && <p>{featured.data.description}</p>}
          <span>read →</span>
        </a>
      ) : (
        <div class="writing-feature writing-feature--empty">
          <h2 id="writing-title">Writing starts here.</h2>
          <p>Add a post to surface the latest writing on the homepage.</p>
        </div>
      )
    }
  </div>

  <aside class="post-rail" aria-label="Post rail">
    <div class="post-rail__header">
      <SectionLabel tone="blue">Post Rail</SectionLabel>
      <a href="/posts/">all writing</a>
    </div>
    <div class="post-rail__list">
      {
        posts.map((post) => (
          <a class={featured?.id === post.id ? 'is-active' : ''} href={postHref(post)}>
            <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
            <strong>{post.data.title}</strong>
          </a>
        ))
      }
    </div>
  </aside>
</section>

<style>
  .writing-surface {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.7fr);
    gap: clamp(var(--s-6), 5vw, var(--s-12));
    align-items: start;
  }

  .writing-surface__preview {
    min-width: 0;
  }

  .writing-feature {
    display: grid;
    gap: var(--s-5);
    margin-top: var(--s-4);
    padding: clamp(var(--s-5), 4vw, var(--s-8));
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    background: rgba(14, 16, 20, 0.72);
  }

  .writing-feature h2 {
    max-width: 760px;
    margin: 0;
    color: #fff;
    font-size: clamp(34px, 5vw, 54px);
    line-height: 1.04;
  }

  .writing-feature__meta,
  .writing-feature span {
    margin: 0;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .writing-feature img {
    width: min(520px, 100%);
    aspect-ratio: 2 / 1;
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    object-fit: cover;
    filter: brightness(0.9) saturate(0.94);
  }

  .writing-feature > p:not(.writing-feature__meta) {
    max-width: 680px;
    margin: 0;
    color: var(--text-muted);
    font-size: 17px;
    line-height: 1.7;
  }

  .writing-feature span {
    color: var(--accent-pink);
  }

  .post-rail {
    padding-top: var(--s-2);
  }

  .post-rail__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s-4);
    margin-bottom: var(--s-4);
  }

  .post-rail__header a {
    color: var(--accent-blue);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .post-rail__list {
    display: grid;
    border-top: 1px solid var(--border);
  }

  .post-rail__list a {
    display: grid;
    gap: var(--s-2);
    padding: var(--s-5) var(--s-3);
    border-bottom: 1px solid var(--border);
  }

  .post-rail__list a.is-active {
    border-radius: var(--r-md);
    background: rgba(244, 114, 182, 0.055);
    box-shadow: inset 0 0 0 1px rgba(244, 114, 182, 0.1);
  }

  .post-rail time {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .post-rail strong {
    color: #fff;
    font-size: 18px;
    line-height: 1.35;
  }

  @media (max-width: 920px) {
    .writing-surface {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .writing-feature {
      padding: var(--s-5);
    }

    .writing-feature h2 {
      font-size: clamp(30px, 10vw, 42px);
    }

    .post-rail__list a {
      padding-right: 0;
      padding-left: 0;
    }
  }
</style>
