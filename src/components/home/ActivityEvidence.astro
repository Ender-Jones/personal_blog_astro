---
import SectionLabel from '../ui/SectionLabel.astro';
import SectionMarker from '../ui/SectionMarker.astro';
import { getSocialLinks, type SiteData } from '../../lib/data';
import {
  formatDate,
  tagSlug,
  worklogHref,
  type PostEntry,
} from '../../lib/content';
import { getGitActivitySnapshot } from '../../lib/gitActivity';
import type { CurrentThread } from '../../lib/parseWorklog';
import { getHomeTagSummary } from '../../lib/tags';

type Props = {
  thread: CurrentThread;
  posts: PostEntry[];
  site: SiteData;
};

const { thread, posts, site } = Astro.props;
const hasThread = thread.state !== 'collapsed';
const worklog = 'worklog' in thread ? thread.worklog : undefined;
const updatedAt = 'updatedAt' in thread ? thread.updatedAt : undefined;
const href = worklog ? worklogHref(worklog) : '/worklog/';
const source = worklog ? `worklogs/${worklog.id}.md` : 'worklogs/';
const topics = getHomeTagSummary(posts);
const gitActivity = getGitActivitySnapshot();
const gitActivityDays = gitActivity.days;
const hasGitHistory = gitActivity.source === 'git';
const hasGitActivity = gitActivity.totalCommits > 0;
const githubLink = getSocialLinks(site).find((link) => link.key === 'github');
const githubTitle = site.github_card?.title ?? 'Code and research work.';
const githubDescription = site.github_card?.description ?? 'Repositories and experiments connected to this site.';
---

<section class="home-activity" aria-labelledby="activity-title">
  <SectionMarker number="03" name="ACTIVITY" />

  <article class="thread-editorial">
    <div class="thread-editorial__wash" aria-hidden="true"></div>

    <div class="thread-editorial__main">
      <div>
        <div class="thread-editorial__stamp">
          <b>$</b>
          <span>public:thread</span>
        </div>
        <small>
          {updatedAt ? `updated ${formatDate(updatedAt)}` : 'quiet'} · sourced from <em>{source}</em>
        </small>
      </div>

      <div class="thread-editorial__headline">
        <i aria-hidden="true"></i>
        <div>
          <h2 id="activity-title">{hasThread ? thread.summary : 'No public thread set yet.'}</h2>
        </div>
      </div>
    </div>

    <aside class="thread-editorial__side">
      <div>
        <span>public bullets</span>
        <i></i>
      </div>
      {
        hasThread && thread.bullets.length > 0 && (
          <ul>
            {thread.bullets.map((bullet) => (
              <li>{bullet}</li>
            ))}
          </ul>
        )
      }
      <a href={href}>open worklog →</a>
    </aside>
  </article>

  <div class="activity-bottom">
    {
      githubLink && (
        <a class="github-card" href={githubLink.href}>
          <div class="github-card__top">
            <SectionLabel tone="blue">GitHub</SectionLabel>
            <span>{githubLink?.value ?? 'GitHub'}</span>
          </div>
          <div class="github-card__copy">
            <strong>{githubTitle}</strong>
            <p>{githubDescription}</p>
          </div>

          <div
            class={hasGitHistory && hasGitActivity ? 'commit-wall' : 'commit-wall commit-wall--empty'}
            aria-label="Site commit activity"
          >
            <ol aria-hidden="true">
              {
                gitActivityDays.map((day) => (
                  <li
                    class={`level-${day.level}`}
                    title={`${day.date}: ${day.count} commit${day.count === 1 ? '' : 's'}`}
                  ></li>
                ))
              }
            </ol>
            {
              (!hasGitHistory || !hasGitActivity) && (
                <p>
                  {hasGitHistory
                    ? 'No commits in this build window.'
                    : 'No git history available in this build.'}
                </p>
              )
            }
          </div>
        </a>
      )
    }

    <article class="topics-index">
      <div class="topics-index__top">
        <SectionLabel tone="pink">Tag index</SectionLabel>
        <span>sorted by frequency</span>
      </div>

      <ol>
        {
          topics.map(({ tag, count, tone }) => (
            <li class={`topic-tone-${tone}`}>
              <a href={`/tags/${tagSlug(tag)}/`}>#{tag}</a>
              <i></i>
              <span>{String(count).padStart(2, '0')}</span>
            </li>
          ))
        }
      </ol>

      <div class="topics-index__foot">
        <a href="/tags/">all tags →</a>
      </div>
    </article>
  </div>
</section>

<style>
  .home-activity {
    display: grid;
    gap: var(--s-6);
  }

  .thread-editorial,
  .github-card,
  .topics-index {
    position: relative;
    overflow: hidden;
    border-radius: var(--r-lg);
    background: var(--surface);
    box-shadow:
      0 0 28px rgba(56, 189, 248, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    transition:
      border-color 90ms ease,
      box-shadow 90ms ease;
  }

  .thread-editorial {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 1fr);
    gap: var(--s-6);
    min-height: clamp(220px, 18vw, 260px);
    padding: 28px 32px;
    border: 1px solid rgba(56, 189, 248, 0.22);
  }

  .thread-editorial:hover {
    border-color: rgba(56, 189, 248, 0.32);
    box-shadow:
      0 0 28px rgba(56, 189, 248, 0.075),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .thread-editorial__wash {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(900px 480px at 0% 0%, rgba(56, 189, 248, 0.06), transparent 60%),
      radial-gradient(700px 380px at 100% 100%, rgba(93, 202, 165, 0.04), transparent 65%);
    pointer-events: none;
  }

  .thread-editorial > *:not(.thread-editorial__wash) {
    position: relative;
  }

  .thread-editorial__main > div:first-child {
    display: flex;
    align-items: center;
    gap: var(--s-3);
    margin-bottom: var(--s-5);
  }

  .thread-editorial__stamp {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    padding: 4px 11px;
    border: 1px solid rgba(56, 189, 248, 0.26);
    border-radius: 3px;
    background: rgba(56, 189, 248, 0.08);
  }

  .thread-editorial__stamp b,
  .thread-editorial__stamp span {
    color: var(--accent-blue);
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .thread-editorial__stamp span {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .thread-editorial small {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 10.5px;
  }

  .thread-editorial small em {
    color: var(--text-muted);
    font-style: normal;
  }

  .thread-editorial__headline {
    display: flex;
    align-items: flex-start;
    gap: var(--s-5);
  }

  .thread-editorial__headline > i {
    width: 3px;
    align-self: stretch;
    margin-top: 6px;
    border-radius: 999px;
    background: linear-gradient(180deg, var(--accent-blue), rgba(56, 189, 248, 0.15));
    box-shadow: 0 0 8px rgba(56, 189, 248, 0.35);
  }

  .thread-editorial h2 {
    margin: 0;
    color: #fff;
    font-family: var(--font-serif);
    font-size: clamp(26px, 2.6vw, 32px);
    font-weight: 400;
    letter-spacing: -0.005em;
    line-height: 1.16;
    text-wrap: pretty;
  }

  .thread-editorial__side {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    padding-left: var(--s-6);
    border-left: 1px solid rgba(255, 255, 255, 0.05);
  }

  .thread-editorial__side > div:first-child {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  .thread-editorial__side > div:first-child span {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .thread-editorial__side > div:first-child i {
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.05);
  }

  .thread-editorial ul {
    display: grid;
    gap: var(--s-3);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .thread-editorial li {
    display: flex;
    gap: var(--s-3);
    color: #cfd5dd;
    font-size: 13.5px;
    line-height: 1.45;
  }

  .thread-editorial li::before {
    color: var(--accent-blue);
    font-family: var(--font-mono);
    content: '›';
  }

  .thread-editorial__side > a {
    display: inline-flex;
    width: max-content;
    align-items: center;
    gap: var(--s-2);
    margin-top: auto;
    padding: 8px 16px;
    border: 1px solid rgba(56, 189, 248, 0.42);
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(56, 189, 248, 0.18), rgba(56, 189, 248, 0.06));
    color: #fff;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    box-shadow:
      0 0 18px rgba(56, 189, 248, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  .activity-bottom {
    --activity-card-height: clamp(264px, 21vw, 291px);

    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(320px, 1fr);
    gap: var(--s-4);
    align-items: stretch;
  }

  .github-card,
  .topics-index {
    height: var(--activity-card-height);
    padding: 18px;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .github-card {
    display: grid;
    grid-template-columns: minmax(220px, 0.8fr) minmax(0, 1.2fr);
    grid-template-rows: auto 1fr;
    gap: var(--s-4);
    align-items: stretch;
    border-color: rgba(56, 189, 248, 0.14);
    background:
      radial-gradient(520px 260px at 100% 50%, rgba(56, 189, 248, 0.075), transparent 66%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.018), rgba(255, 255, 255, 0.004)),
      var(--surface);
  }

  .github-card:hover {
    border-color: rgba(56, 189, 248, 0.24);
    box-shadow:
      0 0 28px rgba(56, 189, 248, 0.07),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .github-card__top,
  .github-card__copy {
    grid-column: 1;
    position: relative;
    z-index: 1;
  }

  .github-card__top,
  .topics-index__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
  }

  .github-card__top span,
  .topics-index__top span {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 10px;
  }

  .github-card strong {
    display: block;
    color: #fff;
    font-family: var(--font-serif);
    font-size: clamp(24px, 2.1vw, 30px);
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.06;
    text-wrap: balance;
  }

  .github-card p {
    max-width: 31ch;
    margin: var(--s-4) 0 0;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 10.5px;
    line-height: 1.6;
  }

  .commit-wall {
    position: relative;
    display: flex;
    grid-row: 1 / span 2;
    grid-column: 2;
    min-width: 0;
    min-height: 100%;
    align-self: stretch;
    padding: 10px;
    border: 1px solid rgba(56, 189, 248, 0.14);
    border-radius: var(--r-md);
    background:
      linear-gradient(180deg, rgba(56, 189, 248, 0.065), rgba(56, 189, 248, 0.018)),
      rgba(3, 6, 13, 0.44);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.045),
      0 0 24px rgba(56, 189, 248, 0.055);
    transition:
      border-color 90ms ease,
      box-shadow 90ms ease;
  }

  .commit-wall--empty ol {
    opacity: 0.24;
  }

  .commit-wall > p {
    position: absolute;
    right: 14px;
    bottom: 12px;
    left: 14px;
    margin: 0;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 10px;
    line-height: 1.4;
    text-align: right;
  }

  .github-card:hover .commit-wall {
    border-color: rgba(56, 189, 248, 0.22);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.055),
      0 0 24px rgba(56, 189, 248, 0.075);
  }

  .commit-wall ol {
    display: grid;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    grid-auto-columns: minmax(2px, 1fr);
    grid-auto-flow: column;
    grid-template-rows: repeat(7, minmax(11px, 1fr));
    gap: 3px;
    list-style: none;
  }

  .commit-wall li {
    min-width: 0;
    border: 1px solid rgba(255, 255, 255, 0.03);
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.04);
  }

  .commit-wall .level-1 {
    background: rgba(56, 189, 248, 0.2);
  }

  .commit-wall .level-2 {
    background: rgba(56, 189, 248, 0.36);
    box-shadow: 0 0 8px rgba(56, 189, 248, 0.08);
  }

  .commit-wall .level-3 {
    background: rgba(93, 202, 165, 0.5);
    box-shadow: 0 0 10px rgba(93, 202, 165, 0.12);
  }

  .commit-wall .level-4 {
    background: linear-gradient(135deg, rgba(244, 114, 182, 0.82), rgba(56, 189, 248, 0.68));
    box-shadow: 0 0 12px rgba(244, 114, 182, 0.16);
  }

  .topics-index {
    display: grid;
    grid-template-rows: auto minmax(0, 1fr) auto;
    border-color: rgba(244, 114, 182, 0.12);
    background:
      radial-gradient(420px 240px at 0% 10%, rgba(244, 114, 182, 0.06), transparent 68%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.014), rgba(255, 255, 255, 0.004)),
      var(--surface);
  }

  .topics-index:hover {
    border-color: rgba(244, 114, 182, 0.22);
    box-shadow:
      0 0 28px rgba(244, 114, 182, 0.065),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .topics-index ol {
    display: grid;
    align-content: start;
    gap: 5px;
    margin: var(--s-4) 0 0;
    padding: 0;
    overflow: hidden;
    list-style: none;
  }

  .topics-index li {
    display: flex;
    align-items: baseline;
    gap: var(--s-3);
    min-height: 15px;
    opacity: 0.92;
  }

  .topics-index li a,
  .topics-index li span {
    font-family: var(--font-mono);
  }

  .topics-index li a {
    flex-shrink: 0;
  }

  .topics-index li i {
    flex: 1;
    border-bottom: 1px dotted rgba(255, 255, 255, 0.085);
    transform: translateY(-3px);
  }

  .topics-index li span {
    width: 18px;
    flex-shrink: 0;
    color: var(--text-dim);
    font-size: 11px;
    text-align: right;
  }

  .topics-index li a {
    font-size: 11.5px;
    letter-spacing: 0.01em;
  }

  .topics-index .topic-tone-personal a {
    color: var(--accent-pink);
  }

  .topics-index .topic-tone-research a {
    color: var(--accent-blue);
  }

  .topics-index .topic-tone-neutral a {
    color: var(--text-muted);
  }

  .topics-index li:hover a {
    color: var(--text);
  }

  .topics-index__foot {
    display: flex;
    justify-content: flex-end;
    gap: var(--s-4);
    margin-top: var(--s-4);
    padding-top: var(--s-3);
    border-top: 1px dashed rgba(255, 255, 255, 0.05);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .topics-index__foot a {
    color: var(--text-dim);
  }

  .topics-index__foot a:hover {
    color: var(--accent-blue);
  }

  @media (max-width: 980px) {
    .thread-editorial,
    .activity-bottom {
      grid-template-columns: 1fr;
    }

    .thread-editorial {
      gap: var(--s-8);
    }

    .thread-editorial__side {
      padding-top: var(--s-6);
      padding-left: 0;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      border-left: 0;
    }

    .github-card,
    .topics-index {
      height: auto;
      min-height: 300px;
    }
  }

  @media (max-width: 560px) {
    .thread-editorial,
    .github-card,
    .topics-index {
      padding: var(--s-5);
    }

    .github-card {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      min-height: 0;
    }

    .topics-index {
      min-height: 0;
    }

    .commit-wall {
      grid-row: auto;
      grid-column: auto;
      min-height: 72px;
    }

    .github-card strong {
      font-size: 26px;
    }

    .commit-wall ol {
      grid-template-rows: repeat(7, 8px);
      gap: 3px;
    }

  }
</style>
