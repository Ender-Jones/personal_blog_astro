---
import { execFileSync } from 'node:child_process';
import SectionLabel from '../ui/SectionLabel.astro';
import SectionMarker from '../ui/SectionMarker.astro';
import type { SiteData } from '../../lib/data';
import {
  formatDate,
  getTagCounts,
  tagSlug,
  worklogHref,
  type PostEntry,
} from '../../lib/content';
import type { CurrentThread } from '../../lib/parseWorklog';

type Props = {
  thread: CurrentThread;
  posts: PostEntry[];
  site: SiteData;
};

const { thread, posts, site } = Astro.props;
const hasThread = thread.state !== 'collapsed';
const worklog = 'worklog' in thread ? thread.worklog : undefined;
const updatedAt = 'updatedAt' in thread ? thread.updatedAt : undefined;
const href = worklog ? worklogHref(worklog) : '/worklog/';
const source = worklog ? `worklogs/${worklog.id}.md` : 'worklogs/';
const topics = getTagCounts(posts).sort(([tagA, countA], [tagB, countB]) => countB - countA || tagA.localeCompare(tagB));
const visibleTopics = topics.filter(([, count]) => count >= 2);
const hiddenTopicCount = topics.length - visibleTopics.length;
const gitActivityDays = getGitActivityDays();

function topicTone(tag: string) {
  const normalized = tag.toLowerCase();
  if (normalized.includes('research') || normalized.includes('stress')) return 'teal';
  if (normalized.includes('poem') || normalized.includes('memory') || normalized.includes('blog')) return 'pink';
  if (normalized.includes('other')) return 'muted';
  return 'blue';
}

function getGitActivityDays(weeks = 12) {
  const dayCount = weeks * 7;
  const today = new Date();
  const start = new Date(today);
  start.setDate(today.getDate() - dayCount + 1);
  start.setHours(0, 0, 0, 0);

  const counts = new Map<string, number>();

  try {
    const output = execFileSync(
      'git',
      ['log', `--since=${formatDateKey(start)}`, '--date=format:%Y-%m-%d', '--format=%ad'],
      { encoding: 'utf8' },
    );

    for (const date of output.split('\n').filter(Boolean)) {
      counts.set(date, (counts.get(date) ?? 0) + 1);
    }
  } catch {
    // Git history may be unavailable in some build environments.
  }

  const days = Array.from({ length: dayCount }, (_, index) => {
    const date = new Date(start);
    date.setDate(start.getDate() + index);
    const key = formatDateKey(date);
    const count = counts.get(key) ?? 0;

    return {
      date: key,
      count,
      level: getCommitLevel(count),
    };
  });

  return days;
}

function getCommitLevel(count: number) {
  if (count <= 0) return 0;
  if (count === 1) return 1;
  if (count <= 3) return 2;
  if (count <= 7) return 3;
  return 4;
}

function formatDateKey(date: Date) {
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');

  return `${year}-${month}-${day}`;
}
---

<section class="home-activity" aria-labelledby="activity-title">
  <SectionMarker number="03" name="ACTIVITY" />

  <article class="thread-editorial">
    <div class="thread-editorial__wash" aria-hidden="true"></div>

    <div class="thread-editorial__main">
      <div>
        <div class="thread-editorial__stamp">
          <b>$</b>
          <span>public:thread</span>
        </div>
        <small>
          {updatedAt ? `updated ${formatDate(updatedAt)}` : 'quiet'} · sourced from <em>{source}</em>
        </small>
      </div>

      <div class="thread-editorial__headline">
        <i aria-hidden="true"></i>
        <div>
          <h2 id="activity-title">{hasThread ? thread.summary : 'No public thread set yet.'}</h2>
        </div>
      </div>
    </div>

    <aside class="thread-editorial__side">
      <div>
        <span>public bullets</span>
        <i></i>
      </div>
      {
        hasThread && thread.bullets.length > 0 && (
          <ul>
            {thread.bullets.map((bullet) => (
              <li>{bullet}</li>
            ))}
          </ul>
        )
      }
      <a href={href}>open worklog →</a>
    </aside>
  </article>

  <div class="activity-bottom">
    {
      site.socials.github && (
        <a class="github-card" href={site.socials.github}>
          <div class="github-card__top">
            <SectionLabel tone="blue">GitHub</SectionLabel>
            <span>@Ender-Jones</span>
          </div>
          <div class="github-card__copy">
            <strong>Code, experiments, and small tools.</strong>
            <p>Repositories, experiments, and the rough edges of things I am building.</p>
          </div>

          <div class="commit-wall" aria-label="Site commit activity">
            <ol aria-hidden="true">
              {
                gitActivityDays.map((day) => (
                  <li
                    class={`level-${day.level}`}
                    title={`${day.date}: ${day.count} commit${day.count === 1 ? '' : 's'}`}
                  ></li>
                ))
              }
            </ol>
          </div>
        </a>
      )
    }

    <article class="topics-index">
      <div class="topics-index__top">
        <SectionLabel tone="pink">Tag index</SectionLabel>
        <span>sorted by frequency</span>
      </div>

      <ol>
        {
          visibleTopics.map(([tag, count]) => (
            <li class={`tone-${topicTone(tag)}`}>
              <a href={`/tags/${tagSlug(tag)}/`}>#{tag}</a>
              <i></i>
              <span>{String(count).padStart(2, '0')}</span>
            </li>
          ))
        }
        {
          hiddenTopicCount > 0 && (
            <li class="tone-muted">
              <a href="/tags/">+ {hiddenTopicCount} more</a>
              <i></i>
              <span>all</span>
            </li>
          )
        }
      </ol>

      <div class="topics-index__foot">
        <a href="/tags/">all tags →</a>
      </div>
    </article>
  </div>
</section>

<style>
  .home-activity {
    display: grid;
    gap: var(--s-6);
  }

  .thread-editorial,
  .github-card,
  .topics-index {
    position: relative;
    overflow: hidden;
    border-radius: var(--r-lg);
    background: var(--surface);
    box-shadow:
      0 0 28px rgba(56, 189, 248, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .thread-editorial {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 1fr);
    gap: var(--s-6);
    padding: 24px 28px;
    border: 1px solid rgba(56, 189, 248, 0.22);
  }

  .thread-editorial__wash {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(900px 480px at 0% 0%, rgba(56, 189, 248, 0.06), transparent 60%),
      radial-gradient(700px 380px at 100% 100%, rgba(93, 202, 165, 0.04), transparent 65%);
    pointer-events: none;
  }

  .thread-editorial > *:not(.thread-editorial__wash) {
    position: relative;
  }

  .thread-editorial__main > div:first-child {
    display: flex;
    align-items: center;
    gap: var(--s-3);
    margin-bottom: var(--s-4);
  }

  .thread-editorial__stamp {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    padding: 4px 11px;
    border: 1px solid rgba(56, 189, 248, 0.26);
    border-radius: 3px;
    background: rgba(56, 189, 248, 0.08);
  }

  .thread-editorial__stamp b,
  .thread-editorial__stamp span {
    color: var(--accent-blue);
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .thread-editorial__stamp span {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .thread-editorial small {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 10.5px;
  }

  .thread-editorial small em {
    color: var(--text-muted);
    font-style: normal;
  }

  .thread-editorial__headline {
    display: flex;
    align-items: flex-start;
    gap: var(--s-5);
  }

  .thread-editorial__headline > i {
    width: 3px;
    align-self: stretch;
    margin-top: 6px;
    border-radius: 999px;
    background: linear-gradient(180deg, var(--accent-blue), rgba(56, 189, 248, 0.15));
    box-shadow: 0 0 8px rgba(56, 189, 248, 0.35);
  }

  .thread-editorial h2 {
    margin: 0;
    color: #fff;
    font-family: var(--font-serif);
    font-size: clamp(26px, 2.6vw, 32px);
    font-weight: 400;
    letter-spacing: -0.005em;
    line-height: 1.16;
    text-wrap: pretty;
  }

  .thread-editorial__side {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    padding-left: var(--s-6);
    border-left: 1px solid rgba(255, 255, 255, 0.05);
  }

  .thread-editorial__side > div:first-child {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  .thread-editorial__side > div:first-child span {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .thread-editorial__side > div:first-child i {
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.05);
  }

  .thread-editorial ul {
    display: grid;
    gap: var(--s-3);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .thread-editorial li {
    display: flex;
    gap: var(--s-3);
    color: #cfd5dd;
    font-size: 13.5px;
    line-height: 1.45;
  }

  .thread-editorial li::before {
    color: var(--accent-blue);
    font-family: var(--font-mono);
    content: '›';
  }

  .thread-editorial__side > a {
    display: inline-flex;
    width: max-content;
    align-items: center;
    gap: var(--s-2);
    padding: 8px 16px;
    border: 1px solid rgba(56, 189, 248, 0.42);
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(56, 189, 248, 0.18), rgba(56, 189, 248, 0.06));
    color: #fff;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    box-shadow:
      0 0 18px rgba(56, 189, 248, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  .activity-bottom {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-4);
  }

  .github-card,
  .topics-index {
    min-height: 278px;
    padding: var(--s-6);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .github-card {
    display: grid;
    grid-template-rows: auto auto 1fr;
    gap: var(--s-5);
  }

  .github-card__top,
  .topics-index__top {
    display: flex;
    justify-content: space-between;
    gap: var(--s-4);
  }

  .github-card__top span,
  .topics-index__top span {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 10px;
  }

  .github-card strong {
    display: block;
    max-width: 420px;
    color: #fff;
    font-size: clamp(26px, 2.7vw, 34px);
    line-height: 1.1;
  }

  .github-card p {
    max-width: 480px;
    margin: var(--s-4) 0 0;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.7;
  }

  .commit-wall {
    align-self: end;
    padding-top: var(--s-2);
  }

  .commit-wall ol {
    display: grid;
    margin: 0;
    padding: 0;
    grid-auto-columns: minmax(7px, 1fr);
    grid-auto-flow: column;
    grid-template-rows: repeat(7, 10px);
    gap: 4px;
    list-style: none;
  }

  .commit-wall li {
    min-width: 0;
    border: 1px solid rgba(255, 255, 255, 0.03);
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.045);
  }

  .commit-wall .level-1 {
    background: rgba(56, 189, 248, 0.2);
  }

  .commit-wall .level-2 {
    background: rgba(56, 189, 248, 0.36);
    box-shadow: 0 0 8px rgba(56, 189, 248, 0.08);
  }

  .commit-wall .level-3 {
    background: rgba(93, 202, 165, 0.5);
    box-shadow: 0 0 10px rgba(93, 202, 165, 0.12);
  }

  .commit-wall .level-4 {
    background: linear-gradient(135deg, rgba(244, 114, 182, 0.82), rgba(56, 189, 248, 0.68));
    box-shadow: 0 0 12px rgba(244, 114, 182, 0.16);
  }

  .topics-index {
    display: flex;
    flex-direction: column;
  }

  .topics-index ol {
    display: grid;
    gap: 7px;
    margin: var(--s-5) 0 0;
    padding: 0;
    list-style: none;
  }

  .topics-index li {
    display: flex;
    align-items: baseline;
    gap: var(--s-3);
  }

  .topics-index li a,
  .topics-index li span {
    font-family: var(--font-mono);
    font-size: 13px;
  }

  .topics-index li a {
    flex-shrink: 0;
  }

  .topics-index li i {
    flex: 1;
    border-bottom: 1px dotted rgba(255, 255, 255, 0.1);
    transform: translateY(-3px);
  }

  .topics-index li span {
    width: 18px;
    flex-shrink: 0;
    color: var(--text-muted);
    font-size: 11px;
    text-align: right;
  }

  .topics-index .tone-blue a {
    color: var(--accent-blue);
  }

  .topics-index .tone-teal a {
    color: var(--accent-teal);
  }

  .topics-index .tone-pink a {
    color: var(--accent-pink);
  }

  .topics-index .tone-muted a {
    color: var(--text-dim);
  }

  .topics-index__foot {
    display: flex;
    justify-content: flex-end;
    gap: var(--s-4);
    margin-top: auto;
    padding-top: var(--s-3);
    border-top: 1px dashed rgba(255, 255, 255, 0.05);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .topics-index__foot a {
    color: var(--accent-pink);
  }

  @media (max-width: 980px) {
    .thread-editorial,
    .activity-bottom {
      grid-template-columns: 1fr;
    }

    .thread-editorial {
      gap: var(--s-8);
    }

    .thread-editorial__side {
      padding-top: var(--s-6);
      padding-left: 0;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      border-left: 0;
    }
  }

  @media (max-width: 560px) {
    .thread-editorial,
    .github-card,
    .topics-index {
      padding: var(--s-5);
    }

    .github-card {
      min-height: 0;
    }

    .github-card strong {
      font-size: 26px;
    }

    .commit-wall ol {
      grid-template-rows: repeat(7, 8px);
      gap: 3px;
    }

  }
</style>
