---
import SectionLabel from '../ui/SectionLabel.astro';
import type { QuoteData, SiteData } from '../../lib/data';

type Props = {
  quote?: QuoteData;
  site: SiteData;
};

const { quote, site } = Astro.props;
const socials = [
  ['github', site.socials.github],
  ['twitter', site.socials.twitter],
  ['email', site.socials.email],
].filter((item): item is [string, string] => Boolean(item[1]));
---

<section class="personality-contact" aria-label="Personality and contact">
  {
    quote && (
      <figure class="marginalia">
        <SectionLabel tone="pink">Marginalia</SectionLabel>
        <blockquote>{quote.text}</blockquote>
        <figcaption>
          {quote.source}
          {quote.work ? `, ${quote.work}` : ''}
        </figcaption>
      </figure>
    )
  }

  <div class="contact-panel">
    <SectionLabel tone="blue">Reach Me</SectionLabel>
    <div>
      {socials.map(([label, href]) => (
        <a href={href}>
          <span>{label}</span>
          <small>{href.replace(/^mailto:/, '')}</small>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .personality-contact {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
    gap: clamp(var(--s-6), 5vw, var(--s-10));
    padding-top: var(--s-2);
  }

  .marginalia,
  .contact-panel {
    min-width: 0;
    margin: 0;
    padding: var(--s-6) 0;
    border-top: 1px solid var(--border);
  }

  .marginalia blockquote {
    max-width: 820px;
    margin: var(--s-5) 0 0;
    color: #fff;
    font-family: var(--font-serif);
    font-size: clamp(28px, 4vw, 44px);
    font-style: italic;
    line-height: 1.2;
  }

  .marginalia figcaption {
    margin-top: var(--s-4);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .contact-panel {
    display: grid;
    gap: var(--s-5);
    align-content: start;
  }

  .contact-panel > div {
    display: grid;
    gap: var(--s-3);
  }

  .contact-panel a {
    display: grid;
    gap: var(--s-1);
    padding-bottom: var(--s-3);
    border-bottom: 1px solid var(--border);
  }

  .contact-panel span {
    color: #fff;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
  }

  .contact-panel small {
    overflow: hidden;
    color: var(--accent-blue);
    font-family: var(--font-mono);
    font-size: 11px;
    text-overflow: ellipsis;
  }

  @media (max-width: 820px) {
    .personality-contact {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .marginalia,
    .contact-panel {
      padding: var(--s-5) 0;
    }
  }
</style>
