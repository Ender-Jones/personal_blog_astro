---
import SectionMarker from '../ui/SectionMarker.astro';
import type { QuoteData, SiteData } from '../../lib/data';

type Props = {
  quote?: QuoteData;
  site: SiteData;
};

const { quote, site } = Astro.props;
const socials = [
  ['github', '⌘', site.socials.github, '@enderjones'],
  ['x', '𝕏', site.socials.twitter, '@enderjones'],
  ['email', '✉', site.socials.email, 'hi@...'],
].filter((item): item is [string, string, string, string] => Boolean(item[2]));
---

<section class="home-coda" aria-label="Personality and contact">
  <SectionMarker number="04" name="MARGINALIA" />

  {
    quote && (
      <figure class="marginalia">
        <div class="marginalia__photo" aria-hidden="true"></div>
        <div class="marginalia__shade" aria-hidden="true"></div>

        <div class="marginalia__body">
          <blockquote>{quote.text}</blockquote>
          <figcaption>
            — {quote.source}
            {quote.work ? `, ${quote.work}` : ''}
            {quote.year ? `, ${quote.year}` : ''}
          </figcaption>
        </div>
      </figure>
    )
  }

  <nav class="contact-strip" aria-label="Contact links">
    <span>reach me</span>
    <div>
      {
        socials.map(([label, icon, href, value]) => (
          <a href={href} aria-label={label}>
            <b aria-hidden="true">{icon}</b>
            <small>{value}</small>
          </a>
        ))
      }
    </div>
  </nav>
</section>

<style>
  .home-coda {
    display: grid;
    gap: var(--s-6);
  }

  .marginalia {
    position: relative;
    display: grid;
    min-height: 300px;
    overflow: hidden;
    margin: 0;
    border: 1px solid rgba(244, 114, 182, 0.14);
    border-radius: var(--r-lg);
    background: var(--surface);
    box-shadow:
      0 0 28px rgba(244, 114, 182, 0.03),
      inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }

  .marginalia__photo,
  .marginalia__shade {
    position: absolute;
    inset: 0;
  }

  .marginalia__photo {
    background: url('/img/posts/cherry-blossom-wide.jpg') center 60% / cover;
    filter: brightness(0.35) saturate(0.7) blur(1px);
    opacity: 0.55;
  }

  .marginalia__shade {
    background:
      linear-gradient(90deg, rgba(7, 8, 9, 0.9), rgba(7, 8, 9, 0.74) 45%, rgba(7, 8, 9, 0.38)),
      linear-gradient(180deg, rgba(7, 8, 9, 0.18), rgba(7, 8, 9, 0.88)),
      radial-gradient(760px 320px at 82% 95%, rgba(244, 114, 182, 0.16), transparent 62%),
      radial-gradient(620px 280px at 10% 0%, rgba(56, 189, 248, 0.07), transparent 60%);
  }

  .marginalia__body {
    position: relative;
    display: flex;
    width: 100%;
    flex-direction: column;
    justify-content: center;
    padding: clamp(28px, 5vw, 60px);
  }

  .marginalia blockquote {
    max-width: min(1080px, 100%);
    margin: 0;
    color: #e8eaed;
    font-family: var(--font-serif);
    font-size: clamp(28px, 4vw, 44px);
    font-style: italic;
    font-weight: 300;
    line-height: 1.16;
    overflow-wrap: break-word;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.5);
    text-wrap: pretty;
  }

  .marginalia figcaption {
    margin-top: var(--s-5);
    color: rgba(255, 255, 255, 0.56);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .contact-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-6);
    padding: var(--s-4) 0;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .contact-strip > span {
    color: #fff;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .contact-strip > div {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-3);
  }

  .contact-strip a {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    min-height: 34px;
    padding: 7px 14px 7px 10px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.025);
    font-family: var(--font-mono);
  }

  .contact-strip b {
    display: inline-grid;
    width: 20px;
    height: 20px;
    place-items: center;
    border: 1px solid rgba(56, 189, 248, 0.22);
    border-radius: 999px;
    background: rgba(56, 189, 248, 0.08);
    color: #fff;
    font-size: 12px;
    font-weight: 600;
    line-height: 1;
  }

  .contact-strip small {
    color: var(--accent-blue);
    font-size: 10.5px;
  }

  @media (max-width: 560px) {
    .marginalia {
      min-height: 260px;
    }

    .marginalia__body {
      padding: var(--s-5);
    }

    .marginalia blockquote {
      max-width: 100%;
      font-size: clamp(24px, 8vw, 31px);
      line-height: 1.24;
      text-wrap: pretty;
    }

    .marginalia figcaption {
      font-size: 10px;
      line-height: 1.6;
    }

    .contact-strip {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--s-4);
    }

    .contact-strip > div {
      width: 100%;
    }

    .contact-strip a {
      justify-content: space-between;
      width: 100%;
    }
  }
</style>
