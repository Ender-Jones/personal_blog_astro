---
import SectionLabel from '../ui/SectionLabel.astro';
import type { QuoteData, SiteData } from '../../lib/data';

type Props = {
  quote?: QuoteData;
  site: SiteData;
};

const { quote, site } = Astro.props;
const socials = [
  ['github', site.socials.github, '@enderjones'],
  ['x', site.socials.twitter, '@enderjones'],
  ['email', site.socials.email, 'hi@...'],
].filter((item): item is [string, string, string] => Boolean(item[1]));
---

<section class="home-coda" aria-label="Personality and contact">
  <header class="home-section-head">
    <SectionLabel tone="pink">§ 04 · marginalia</SectionLabel>
    <span>quiet decorative coda</span>
  </header>

  {
    quote && (
      <figure class="marginalia">
        <div class="marginalia__photo" aria-hidden="true"></div>
        <div class="marginalia__shade" aria-hidden="true"></div>

        <div class="marginalia__body">
          <div class="marginalia__kicker">
            <SectionLabel tone="pink">※ Marginalia</SectionLabel>
            <span>quotes.yml</span>
          </div>
          <blockquote>{quote.text}</blockquote>
          <figcaption>
            — {quote.source}
            {quote.work ? `, ${quote.work}` : ''}
            {quote.year ? `, ${quote.year}` : ''}
          </figcaption>
        </div>

        <div class="marginalia__annotation" aria-hidden="true">
          <span>handwritten edge</span>
          <i></i>
          <small>personal archive</small>
        </div>
      </figure>
    )
  }

  <nav class="contact-strip" aria-label="Contact links">
    <span>reach me</span>
    <div>
      {
        socials.map(([label, href, value]) => (
          <a href={href}>
            <b>{label}</b>
            <small>{value}</small>
          </a>
        ))
      }
    </div>
  </nav>
</section>

<style>
  .home-coda {
    display: grid;
    gap: var(--s-6);
  }

  .home-section-head {
    display: flex;
    align-items: baseline;
    gap: var(--s-5);
  }

  .home-section-head::after {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(244, 114, 182, 0.2), transparent 75%);
    content: '';
  }

  .home-section-head span {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .marginalia {
    position: relative;
    min-height: 310px;
    overflow: hidden;
    margin: 0;
    border: 1px solid rgba(244, 114, 182, 0.14);
    border-radius: var(--r-lg);
    background: var(--surface);
    box-shadow:
      0 0 28px rgba(244, 114, 182, 0.03),
      inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }

  .marginalia__photo,
  .marginalia__shade {
    position: absolute;
    inset: 0;
  }

  .marginalia__photo {
    background: url('/img/posts/cherry-blossom-wide.jpg') center 60% / cover;
    filter: brightness(0.35) saturate(0.7) blur(1px);
    opacity: 0.55;
  }

  .marginalia__shade {
    background:
      linear-gradient(90deg, rgba(7, 8, 9, 0.9), rgba(7, 8, 9, 0.74) 45%, rgba(7, 8, 9, 0.38)),
      linear-gradient(180deg, rgba(7, 8, 9, 0.18), rgba(7, 8, 9, 0.88)),
      radial-gradient(760px 320px at 82% 95%, rgba(244, 114, 182, 0.16), transparent 62%),
      radial-gradient(620px 280px at 10% 0%, rgba(56, 189, 248, 0.07), transparent 60%);
  }

  .marginalia__body {
    position: relative;
    display: flex;
    height: 100%;
    flex-direction: column;
    justify-content: center;
    padding: clamp(var(--s-7), 6vw, 72px);
  }

  .marginalia__kicker,
  .marginalia__annotation {
    display: flex;
    align-items: center;
    gap: var(--s-3);
  }

  .marginalia__kicker span,
  .marginalia__annotation span,
  .marginalia__annotation small {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .marginalia blockquote {
    max-width: 880px;
    margin: var(--s-6) 0 0;
    color: #e8eaed;
    font-family: var(--font-serif);
    font-size: clamp(30px, 5vw, 54px);
    font-style: italic;
    font-weight: 300;
    letter-spacing: -0.01em;
    line-height: 1.18;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.5);
    text-wrap: balance;
  }

  .marginalia figcaption {
    margin-top: var(--s-6);
    color: rgba(255, 255, 255, 0.56);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .marginalia__annotation {
    position: absolute;
    right: var(--s-8);
    bottom: var(--s-7);
    z-index: 1;
    width: min(260px, 32%);
  }

  .marginalia__annotation i {
    flex: 1;
    height: 1px;
    background: rgba(244, 114, 182, 0.2);
  }

  .contact-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-6);
    padding: var(--s-4) 0;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .contact-strip > span {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .contact-strip > div {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-3);
  }

  .contact-strip a {
    display: inline-flex;
    align-items: baseline;
    gap: var(--s-2);
    padding: 7px 14px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.025);
    font-family: var(--font-mono);
  }

  .contact-strip b {
    color: #fff;
    font-size: 11px;
    font-weight: 600;
  }

  .contact-strip small {
    color: var(--accent-blue);
    font-size: 10.5px;
  }

  @media (max-width: 920px) {
    .home-section-head {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--s-3);
    }

    .home-section-head::after {
      width: 100%;
      flex: none;
    }

    .marginalia__annotation {
      display: none;
    }
  }

  @media (max-width: 560px) {
    .marginalia {
      min-height: 280px;
    }

    .marginalia__body {
      padding: var(--s-5);
    }

    .marginalia blockquote {
      font-size: clamp(25px, 9vw, 34px);
      line-height: 1.28;
      text-wrap: pretty;
    }

    .contact-strip {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--s-4);
    }

    .contact-strip > div {
      width: 100%;
    }

    .contact-strip a {
      justify-content: space-between;
      width: 100%;
    }
  }
</style>
