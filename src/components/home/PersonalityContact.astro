---
import SectionMarker from '../ui/SectionMarker.astro';
import type { MarginaliaItem } from '../../lib/marginalia';

type Props = {
  marginalia?: MarginaliaItem;
};

const { marginalia } = Astro.props;
const backgroundStyle = marginalia
  ? `--marginalia-image: url("${marginalia.image}"); --marginalia-focus: ${marginalia.imageFocus};`
  : undefined;
---

{
  marginalia && (
    <section class="home-coda" aria-label="Personality and contact">
      <SectionMarker number="04" name="MARGINALIA" />

      <figure class="marginalia" style={backgroundStyle}>
        <div class="marginalia__photo" aria-hidden="true"></div>
        <div class="marginalia__shade" aria-hidden="true"></div>

        <div class="marginalia__body">
          <blockquote>{marginalia.text}</blockquote>
          <figcaption>
            — <a href={marginalia.href}>{marginalia.source}</a>
          </figcaption>
        </div>
      </figure>
    </section>
  )
}

<style>
  .home-coda {
    display: grid;
    gap: var(--s-6);
  }

  .marginalia {
    position: relative;
    display: grid;
    min-height: 240px;
    overflow: hidden;
    margin: 0;
    border: 1px solid rgba(244, 114, 182, 0.14);
    border-radius: var(--r-lg);
    background: var(--surface);
    box-shadow:
      0 0 28px rgba(244, 114, 182, 0.03),
      inset 0 1px 0 rgba(255, 255, 255, 0.03);
    transition:
      border-color 90ms ease,
      box-shadow 90ms ease;
  }

  .marginalia:hover {
    border-color: rgba(244, 114, 182, 0.24);
    box-shadow:
      0 0 28px rgba(244, 114, 182, 0.055),
      inset 0 1px 0 rgba(255, 255, 255, 0.045);
  }

  .marginalia__photo,
  .marginalia__shade {
    position: absolute;
    inset: 0;
  }

  .marginalia__photo {
    background: var(--marginalia-image) var(--marginalia-focus, center 60%) / cover;
    filter: brightness(0.35) saturate(0.7) blur(1px);
    opacity: 0.55;
  }

  .marginalia__shade {
    background:
      linear-gradient(90deg, rgba(7, 8, 9, 0.9), rgba(7, 8, 9, 0.74) 45%, rgba(7, 8, 9, 0.38)),
      linear-gradient(180deg, rgba(7, 8, 9, 0.18), rgba(7, 8, 9, 0.88)),
      radial-gradient(760px 320px at 82% 95%, rgba(244, 114, 182, 0.16), transparent 62%),
      radial-gradient(620px 280px at 10% 0%, rgba(56, 189, 248, 0.07), transparent 60%);
  }

  .marginalia__body {
    position: relative;
    display: flex;
    width: 100%;
    flex-direction: column;
    justify-content: center;
    padding: clamp(24px, 4vw, 44px);
  }

  .marginalia blockquote {
    max-width: min(1080px, 100%);
    margin: 0;
    color: #e8eaed;
    font-family: var(--font-serif);
    font-size: clamp(28px, 4vw, 44px);
    font-style: italic;
    font-weight: 300;
    line-height: 1.16;
    overflow-wrap: break-word;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.5);
    text-wrap: pretty;
    white-space: pre-line;
  }

  .marginalia figcaption {
    margin-top: var(--s-5);
    color: rgba(255, 255, 255, 0.56);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .marginalia figcaption a {
    color: inherit;
  }

  @media (max-width: 560px) {
    .marginalia {
      min-height: 220px;
    }

    .marginalia__body {
      padding: var(--s-5);
    }

    .marginalia blockquote {
      max-width: 100%;
      font-size: clamp(24px, 8vw, 31px);
      line-height: 1.24;
      text-wrap: pretty;
    }

    .marginalia figcaption {
      font-size: 10px;
      line-height: 1.6;
    }

  }
</style>
