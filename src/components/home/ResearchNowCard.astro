---
import type { ResearchData } from '../../lib/data';

type Props = {
  research: ResearchData;
};

const { research } = Astro.props;
const updated = new Intl.DateTimeFormat('en', {
  timeZone: 'Asia/Tokyo',
  year: 'numeric',
  month: '2-digit',
}).format(new Date(research.updated));
---

<article class="thesis-card">
  <div class="thesis-card__wash" aria-hidden="true"></div>
  <span class="thesis-card__corner thesis-card__corner--tl" aria-hidden="true"></span>
  <span class="thesis-card__corner thesis-card__corner--br" aria-hidden="true"></span>

  <div class="thesis-card__stamp">
    <span>※ The Thesis</span>
    <i></i>
    <small>{updated}</small>
  </div>

  <div>
    <h2>
      Stress detection from <em>multi-modal</em> physiological signals.
    </h2>
    <p>What I'm building, on the bench and on paper.</p>
  </div>
</article>

<style>
  .thesis-card {
    position: relative;
    display: flex;
    min-height: 0;
    overflow: hidden;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--s-4);
    padding: 22px 28px;
    border: 1px solid rgba(93, 202, 165, 0.2);
    border-radius: var(--r-lg);
    background: var(--surface);
    box-shadow:
      0 0 28px rgba(93, 202, 165, 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .thesis-card__wash {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(420px 220px at 100% 100%, rgba(93, 202, 165, 0.08), transparent 60%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.005), transparent);
    pointer-events: none;
  }

  .thesis-card__corner {
    position: absolute;
    width: 16px;
    height: 16px;
    opacity: 0.9;
  }

  .thesis-card__corner--tl {
    top: 14px;
    left: 14px;
    border-top: 1px solid rgba(93, 202, 165, 0.45);
    border-left: 1px solid rgba(93, 202, 165, 0.45);
  }

  .thesis-card__corner--br {
    right: 14px;
    bottom: 14px;
    border-right: 1px solid rgba(93, 202, 165, 0.45);
    border-bottom: 1px solid rgba(93, 202, 165, 0.45);
  }

  .thesis-card > *:not(.thesis-card__wash, .thesis-card__corner) {
    position: relative;
  }

  .thesis-card__stamp {
    display: flex;
    align-items: center;
    gap: var(--s-3);
  }

  .thesis-card__stamp > span {
    padding: 3px 10px;
    border: 1px solid rgba(93, 202, 165, 0.25);
    border-radius: 3px;
    background: rgba(93, 202, 165, 0.04);
    color: var(--accent-teal);
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .thesis-card__stamp i {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(93, 202, 165, 0.2), transparent);
  }

  .thesis-card__stamp small {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
  }

  .thesis-card h2 {
    margin: 0;
    color: #fff;
    font-family: var(--font-serif);
    font-size: clamp(23px, 2.15vw, 28px);
    font-weight: 400;
    letter-spacing: -0.005em;
    line-height: 1.18;
    text-wrap: pretty;
  }

  .thesis-card h2 em {
    color: var(--accent-teal);
    font-style: italic;
  }

  .thesis-card p {
    max-width: 360px;
    margin: var(--s-3) 0 0;
    color: var(--text-muted);
    font-family: var(--font-serif);
    font-size: 13px;
    font-style: italic;
    line-height: 1.55;
  }
</style>
