<div class="site-backdrop" aria-hidden="true">
  <span class="site-backdrop__glow site-backdrop__glow--pink" data-parallax-glow data-depth="0.34"></span>
  <span class="site-backdrop__glow site-backdrop__glow--blue" data-parallax-glow data-depth="0.43"></span>
  <span class="site-backdrop__glow site-backdrop__glow--teal" data-parallax-glow data-depth="0.28"></span>
</div>

<script is:inline>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  const glows = [...document.querySelectorAll('[data-parallax-glow]')];
  let ticking = false;

  function updateBackdrop() {
    ticking = false;
    if (reduceMotion.matches) {
      for (const glow of glows) glow.style.transform = 'none';
      return;
    }

    const scrollY = window.scrollY || window.pageYOffset || 0;

    for (const glow of glows) {
      const depth = Number(glow.getAttribute('data-depth') || 0.35);
      glow.style.transform = `translate3d(0, ${scrollY * depth * -1}px, 0)`;
    }
  }

  function requestBackdropUpdate() {
    if (ticking || reduceMotion.matches) return;
    ticking = true;
    window.requestAnimationFrame(updateBackdrop);
  }

  updateBackdrop();
  window.addEventListener('scroll', requestBackdropUpdate, { passive: true });
  reduceMotion.addEventListener('change', updateBackdrop);
</script>

<style>
  .site-backdrop {
    position: fixed;
    inset: 0;
    z-index: 0;
    width: 100vw;
    height: 100dvh;
    min-height: 100lvh;
    pointer-events: none;
    overflow: hidden;
    background-image:
      radial-gradient(1100px 680px at 12% 12%, rgba(244, 114, 182, 0.055), transparent 66%),
      radial-gradient(920px 580px at 88% 36%, rgba(56, 189, 248, 0.045), transparent 68%),
      radial-gradient(760px 520px at 50% 112%, rgba(93, 202, 165, 0.03), transparent 70%),
      linear-gradient(to right, rgba(148, 163, 184, 0.025) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(148, 163, 184, 0.025) 1px, transparent 1px),
      linear-gradient(180deg, rgba(4, 6, 13, 0.99), rgba(4, 6, 13, 0.965));
    background-size:
      auto,
      auto,
      auto,
      44px 44px,
      44px 44px,
      auto;
  }

  .site-backdrop__glow {
    position: absolute;
    display: block;
    pointer-events: none;
    will-change: transform;
  }

  .site-backdrop__glow--pink {
    top: 24vh;
    left: -18vw;
    width: 78vw;
    height: 72vh;
    opacity: 0.07;
    background: radial-gradient(closest-side, rgba(244, 114, 182, 0.9), transparent 68%);
  }

  .site-backdrop__glow--blue {
    top: 52vh;
