---
import type { PostEntry } from '../../lib/content';
import { formatDate, postHref } from '../../lib/content';

type Props = {
  newer?: PostEntry;
  older?: PostEntry;
};

const { newer, older } = Astro.props;
const hasLinks = Boolean(newer || older);
---

{
  hasLinks && (
    <nav class="post-prev-next" aria-label="Post navigation">
      {older ? (
        <a href={postHref(older)}>
          <span>Older</span>
          <strong>{older.data.title}</strong>
          <small>{formatDate(older.data.date)}</small>
        </a>
      ) : (
        <span class="post-prev-next__empty" aria-hidden="true" />
      )}

      {newer ? (
        <a class="post-prev-next__newer" href={postHref(newer)}>
          <span>Newer</span>
          <strong>{newer.data.title}</strong>
          <small>{formatDate(newer.data.date)}</small>
        </a>
      ) : (
        <span class="post-prev-next__empty" aria-hidden="true" />
      )}
    </nav>
  )
}

<style>
  .post-prev-next {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--s-4);
    width: min(720px, calc(100% - 32px));
    margin: var(--s-12) auto 0;
  }

  .post-prev-next a,
  .post-prev-next__empty {
    min-height: 132px;
  }

  .post-prev-next a {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--s-5);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    background: rgba(14, 16, 20, 0.72);
  }

  .post-prev-next a:hover {
    border-color: rgba(56, 189, 248, 0.26);
  }

  .post-prev-next span,
  .post-prev-next small {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .post-prev-next strong {
    display: block;
    margin: var(--s-3) 0;
    color: #fff;
    font-size: 17px;
    line-height: 1.35;
  }

  .post-prev-next__newer {
    text-align: right;
  }

  @media (max-width: 640px) {
    .post-prev-next {
      grid-template-columns: 1fr;
      margin-top: var(--s-10);
    }

    .post-prev-next__empty {
      display: none;
    }

    .post-prev-next__newer {
      text-align: left;
    }
  }
</style>
