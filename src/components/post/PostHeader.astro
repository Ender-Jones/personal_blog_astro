---
import type { PostEntry } from '../../lib/content';
import { formatDate, getCoverMode } from '../../lib/content';

type Props = {
  post: PostEntry;
};

const { post } = Astro.props;
const coverMode = getCoverMode(post);
const hasImage = Boolean(post.data.image && coverMode !== 'none');
const showInlineImage = hasImage && coverMode !== 'showcase';
const showShowcase = hasImage && coverMode === 'showcase';
---

<header class={`post-header post-header--${coverMode}`} style={`--post-image-focus: ${post.data.image_focus};`}>
  {showInlineImage && <img src={post.data.image} alt="" aria-hidden="true" />}
  <div class="post-header__body">
    <p class="eyebrow">{post.data.pinned ? 'Pinned Essay' : 'Writing'} · {formatDate(post.data.date)}</p>
    <h1>{post.data.title}</h1>
    {post.data.description && <p>{post.data.description}</p>}
    <div class="post-header__tags" aria-label="Post tags">
      {post.data.tags.map((tag) => <span>#{tag}</span>)}
    </div>
  </div>
</header>

{
  showShowcase && (
    <figure class="post-showcase">
      <img src={post.data.image} alt={post.data.image_alt ?? post.data.title} />
      {post.data.image_alt && <figcaption>{post.data.image_alt}</figcaption>}
    </figure>
  )
}

<style>
  .post-header {
    position: relative;
    overflow: hidden;
    min-height: 320px;
  }

  .post-header--none,
  .post-header--showcase {
    min-height: 0;
  }

  .post-header--strip {
    min-height: 220px;
  }

  .post-header > img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--post-image-focus, 50% 50%);
    filter: brightness(0.68) saturate(0.92);
  }

  .post-header--strip > img {
    filter: brightness(0.48) saturate(0.85) blur(2px);
  }

  .post-header::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(7, 8, 9, 0.2), rgba(7, 8, 9, 0.95));
  }

  .post-header--none::after,
  .post-header--showcase::after {
    content: none;
  }

  .post-header__body {
    position: relative;
    z-index: 1;
    width: min(860px, calc(100% - 40px));
    margin: 0 auto;
    padding: var(--s-16) 0 var(--s-10);
  }

  .post-header--hero-large .post-header__body {
    padding-top: 220px;
  }

  .post-header h1 {
    max-width: 860px;
    margin: var(--s-4) 0;
    color: #fff;
    font-size: clamp(38px, 7vw, 64px);
    line-height: 1.1;
  }

  .post-header__body > p:not(.eyebrow) {
    max-width: 720px;
    margin: 0;
    color: var(--text-muted);
    font-size: 17px;
    line-height: 1.65;
  }

  .post-header__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    margin-top: var(--s-5);
  }

  .post-header__tags span {
    padding: 3px 8px;
    border-radius: var(--r-sm);
    background: rgba(255, 255, 255, 0.05);
    color: #cfd5dd;
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .post-showcase {
    width: min(960px, calc(100% - 40px));
    margin: 0 auto var(--s-12);
  }

  .post-showcase img {
    width: 100%;
    max-height: 560px;
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    object-fit: contain;
    background: var(--surface);
  }

  .post-showcase figcaption {
    margin-top: var(--s-3);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 11px;
    text-align: center;
  }

  @media (max-width: 720px) {
    .post-header {
      min-height: 260px;
    }

    .post-header--none,
    .post-header--showcase {
      min-height: 0;
    }

    .post-header--strip {
      min-height: 180px;
    }

    .post-header__body {
      width: min(100% - 32px, 720px);
      padding: var(--s-10) 0 var(--s-8);
    }

    .post-header--hero-large .post-header__body {
      padding-top: 150px;
    }

    .post-header h1 {
      font-size: clamp(34px, 12vw, 48px);
    }

    .post-header__body > p:not(.eyebrow) {
      font-size: 16px;
    }

    .post-showcase {
      width: min(100% - 32px, 720px);
      margin-bottom: var(--s-8);
    }
  }
</style>
