---
import type { PostEntry } from '../../lib/content';
import { formatPostDate, getCoverMode } from '../../lib/content';

type Props = {
  post: PostEntry;
  readingMinutes: number;
};

const { post, readingMinutes } = Astro.props;
const coverMode = getCoverMode(post);
const hasImage = Boolean(post.data.image && coverMode !== 'none');
const showBackdropImage = hasImage && coverMode !== 'showcase';
const showShowcase = hasImage && coverMode === 'showcase';
const year = post.data.date.getFullYear();
---

<header class={`post-header post-header--${coverMode}`} style={`--post-image-focus: ${post.data.image_focus};`}>
  {showBackdropImage && <img src={post.data.image} alt="" aria-hidden="true" />}
  <div class="post-header__body">
    <p class="eyebrow">{post.data.pinned ? '★ Pinned' : 'Writing'} · Essay · {year}</p>
    <h1>{post.data.title}</h1>
    {post.data.description && <p>{post.data.description}</p>}
    <div class="post-header__meta" aria-label="Post metadata">
      <time datetime={post.data.date.toISOString()}>{formatPostDate(post.data.date)}</time>
      <span class="post-header__sep">·</span>
      <span>{readingMinutes} min read</span>
      {
        post.data.i18n_alt && (
          <>
            <span class="post-header__sep">·</span>
            <a href={`/posts/${post.data.i18n_alt}/`}>中文 version →</a>
          </>
        )
      }
      <span class="post-header__sep">·</span>
      {post.data.tags.map((tag) => <span class="post-header__tag">#{tag}</span>)}
    </div>
  </div>
</header>

{
  showShowcase && (
    <figure class="post-showcase">
      <img src={post.data.image} alt={post.data.image_alt ?? post.data.title} />
      {post.data.image_alt && <figcaption>{post.data.image_alt}</figcaption>}
    </figure>
  )
}

<style>
  .post-header {
    position: relative;
    overflow: hidden;
    min-height: 0;
  }

  .post-header--hero-large {
    min-height: clamp(420px, 44vw, 560px);
  }

  .post-header--hero-small {
    border-bottom: 1px solid var(--border);
  }

  .post-header > img {
    width: 100%;
    object-fit: cover;
    object-position: var(--post-image-focus, 50% 50%);
  }

  .post-header--hero-large > img {
    position: absolute;
    inset: 0;
    height: 100%;
    filter: brightness(0.58) saturate(0.9);
  }

  .post-header--hero-small > img {
    height: clamp(190px, 22vw, 280px);
    border-bottom: 1px solid var(--border);
    filter: brightness(0.72) saturate(0.9);
  }

  .post-header--strip > img {
    height: clamp(72px, 10vw, 120px);
    filter: brightness(0.42) saturate(0.82) blur(2px);
    transform: scale(1.025);
  }

  .post-header--hero-large::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(7, 8, 9, 0.18), rgba(7, 8, 9, 0.54)),
      linear-gradient(180deg, rgba(7, 8, 9, 0.16), rgba(7, 8, 9, 0.92));
  }

  .post-header__body {
    position: relative;
    z-index: 1;
    width: min(960px, calc(100% - clamp(40px, 8vw, 160px)));
    margin: 0 auto;
    padding: var(--s-12) 0 0;
  }

  .post-header--hero-large .post-header__body {
    width: min(1720px, calc(100% - clamp(40px, 8vw, 160px)));
    padding: clamp(96px, 12vw, 128px) 0 var(--s-12);
  }

  .post-header--hero-small .post-header__body {
    padding-top: var(--s-10);
  }

  .post-header--strip .post-header__body {
    padding-top: var(--s-12);
  }

  .post-header--showcase .post-header__body {
    padding-bottom: var(--s-4);
  }

  .post-header h1 {
    max-width: 860px;
    margin: var(--s-5) 0 var(--s-4);
    color: #fff;
    font-size: clamp(42px, 5vw, 58px);
    line-height: 1.1;
  }

  .post-header--hero-large h1 {
    font-size: clamp(56px, 7vw, 86px);
  }

  .post-header--strip h1,
  .post-header--none h1 {
    font-size: clamp(38px, 4.8vw, 52px);
  }

  .post-header__body > p:not(.eyebrow) {
    max-width: 720px;
    margin: 0;
    color: var(--text-muted);
    font-size: 18px;
    line-height: 1.65;
  }

  .post-header--hero-large .post-header__body > p:not(.eyebrow) {
    color: #aab3bf;
    font-size: 23px;
  }

  .post-header__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-3);
    align-items: center;
    margin-top: var(--s-8);
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 14px;
  }

  .post-header__meta a {
    color: var(--accent-blue);
  }

  .post-header__sep {
    color: var(--text-dim);
  }

  .post-header__tag {
    padding: 3px 8px;
    border-radius: var(--r-sm);
    background: rgba(255, 255, 255, 0.05);
    color: #fff;
  }

  .post-showcase {
    width: min(960px, calc(100% - 40px));
    margin: var(--s-6) auto var(--s-12);
  }

  .post-showcase img {
    width: 100%;
    max-height: 560px;
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    object-fit: contain;
    background: var(--surface);
  }

  .post-showcase figcaption {
    margin-top: var(--s-3);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 11px;
    text-align: center;
  }

  @media (max-width: 720px) {
    .post-header--hero-large {
      min-height: 360px;
    }

    .post-header--hero-small > img {
      height: 180px;
    }

    .post-header--strip > img {
      height: 76px;
    }

    .post-header__body {
      width: min(100% - 32px, 720px);
      padding-top: var(--s-8);
    }

    .post-header--hero-large .post-header__body {
      width: min(100% - 32px, 720px);
      padding-top: var(--s-16);
    }

    .post-header--strip .post-header__body {
      padding-top: var(--s-8);
    }

    .post-header h1 {
      font-size: clamp(38px, 11vw, 50px);
    }

    .post-header--hero-large h1 {
      font-size: clamp(42px, 13vw, 56px);
    }

    .post-header--strip h1,
    .post-header--none h1 {
      font-size: clamp(36px, 11vw, 48px);
    }

    .post-header__body > p:not(.eyebrow) {
      font-size: 17px;
    }

    .post-header--hero-large .post-header__body > p:not(.eyebrow) {
      font-size: 17px;
    }

    .post-header__meta {
      gap: var(--s-2);
      margin-top: var(--s-5);
      font-size: 12px;
    }

    .post-showcase {
      width: min(100% - 32px, 720px);
      margin-bottom: var(--s-8);
    }
  }
</style>
