---
import type { PostEntry } from '../../lib/content';
import { formatDate, postHref } from '../../lib/content';

type Props = {
  post: PostEntry;
};

const { post } = Astro.props;
---

<article class="post-row">
  <time>{formatDate(post.data.date)}</time>
  {post.data.image && <img src={post.data.image} alt="" aria-hidden="true" loading="lazy" />}
  <a href={postHref(post)}>
    <h3>{post.data.title}</h3>
    {post.data.description && <p>{post.data.description}</p>}
  </a>
  <div class="post-row__tags">
    {post.data.tags.slice(0, 3).map((tag) => <span>#{tag}</span>)}
  </div>
</article>

<style>
  .post-row {
    display: grid;
    grid-template-columns: 110px 72px minmax(0, 1fr) auto;
    gap: var(--s-5);
    align-items: center;
    padding: var(--s-5) var(--s-6);
    border-bottom: 1px solid var(--border);
  }

  .post-row:last-child {
    border-bottom: 0;
  }

  .post-row time {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .post-row img {
    width: 72px;
    height: 52px;
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    object-fit: cover;
    filter: brightness(0.86) saturate(0.92);
  }

  .post-row h3 {
    overflow: hidden;
    margin: 0 0 var(--s-1);
    color: #fff;
    font-size: 16px;
    line-height: 1.35;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .post-row p {
    overflow: hidden;
    margin: 0;
    color: var(--text-muted);
    font-size: 12px;
    line-height: 1.5;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .post-row__tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: var(--s-2);
  }

  .post-row__tags span {
    padding: 3px 7px;
    border-radius: var(--r-sm);
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 10px;
  }

  @media (max-width: 820px) {
    .post-row {
      grid-template-columns: 82px minmax(0, 1fr);
    }

    .post-row img,
    .post-row__tags {
      display: none;
    }
  }
</style>
