---
import type { PostEntry } from '../../lib/content';
import { formatDate, postHref } from '../../lib/content';

type Props = {
  post: PostEntry;
};

const { post } = Astro.props;
const hasImage = Boolean(post.data.image);
---

<article class={hasImage ? 'pinned-hero pinned-hero--with-image' : 'pinned-hero pinned-hero--no-image'}>
  {hasImage && <img src={post.data.image} alt="" aria-hidden="true" loading="lazy" />}
  <a class="pinned-hero__body" href={postHref(post)}>
    <p>★ Pinned</p>
    <h3>{post.data.title}</h3>
    {post.data.description && <span>{post.data.description}</span>}
    <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
  </a>
</article>

<style>
  .pinned-hero {
    display: grid;
    overflow: hidden;
    margin-bottom: var(--s-4);
    border: 1px solid rgba(244, 114, 182, 0.14);
    border-radius: var(--r-lg);
    background: rgba(14, 16, 20, 0.86);
  }

  .pinned-hero--with-image {
    grid-template-columns: minmax(240px, 1.2fr) 1fr;
  }

  .pinned-hero--no-image {
    grid-template-columns: 1fr;
  }

  .pinned-hero img {
    width: 100%;
    height: 100%;
    min-height: 240px;
    object-fit: cover;
    filter: brightness(0.82) saturate(0.9);
  }

  .pinned-hero__body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--s-3);
    padding: var(--s-8);
  }

  .pinned-hero p,
  .pinned-hero time {
    margin: 0;
    color: var(--accent-pink);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .pinned-hero time {
    color: var(--text-dim);
  }

  .pinned-hero h3 {
    margin: 0;
    color: #fff;
    font-size: clamp(22px, 3vw, 28px);
    line-height: 1.25;
  }

  .pinned-hero span {
    color: var(--text-muted);
    font-size: 14px;
    line-height: 1.7;
  }

  @media (max-width: 720px) {
    .pinned-hero {
      grid-template-columns: 1fr;
    }

    .pinned-hero img {
      min-height: 180px;
    }
  }
</style>
