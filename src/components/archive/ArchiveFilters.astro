---
import type { PostEntry } from '../../lib/content';
import { getTagCounts, tagSlug } from '../../lib/content';

type Props = {
  posts: PostEntry[];
};

const { posts } = Astro.props;
const tags = getTagCounts(posts);
const total = posts.length;
const mode = total <= 3 ? 'small' : total <= 12 ? 'compact' : 'full';
---

<section class="archive-filters" aria-label="Archive filters">
  <div class="archive-filters__chips">
    <a class="tag-chip is-active" href="/posts/">all <small>{total}</small></a>
    {
      tags.map(([tag, count]) => (
        <a class="tag-chip" href={`/tags/${tagSlug(tag)}/`}>
          #{tag} <small>{count}</small>
        </a>
      ))
    }
  </div>

  {
    mode !== 'small' && (
      <div class="archive-filters__tools" aria-label="Archive tools">
        {mode === 'full' ? (
          <label class="archive-search">
            <span>Search</span>
            <input type="search" name="q" placeholder="Search posts" />
          </label>
        ) : (
          <span class="archive-search-pill" title="Search becomes useful once the archive is larger">
            search later <kbd>⌘K</kbd>
          </span>
        )}
        <span class="view-toggle" aria-label="Archive view">
          <span>Cards</span>
          <strong>List</strong>
        </span>
      </div>
    )
  }
</section>

<style>
  .archive-filters {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    margin-bottom: var(--s-10);
  }

  .archive-filters__chips,
  .archive-filters__tools {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    align-items: center;
  }

  .tag-chip,
  .archive-search-pill,
  .view-toggle {
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.025);
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .tag-chip {
    padding: 5px 11px;
  }

  .tag-chip.is-active {
    border-color: rgba(244, 114, 182, 0.26);
    background: rgba(244, 114, 182, 0.08);
    color: var(--accent-pink);
  }

  .tag-chip small {
    color: var(--text-dim);
  }

  .archive-search {
    display: flex;
    align-items: center;
    gap: var(--s-2);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .archive-search input {
    width: 220px;
    padding: 8px 11px;
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    background: var(--surface);
    color: var(--text);
    font: inherit;
  }

  .archive-search-pill {
    padding: 7px 11px;
  }

  .archive-search-pill kbd {
    margin-left: var(--s-2);
    padding: 1px 5px;
    border-radius: var(--r-sm);
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-dim);
    font: inherit;
  }

  .view-toggle {
    display: inline-flex;
    overflow: hidden;
    border-radius: var(--r-md);
  }

  .view-toggle span,
  .view-toggle strong {
    padding: 8px 11px;
    font-weight: 400;
  }

  .view-toggle strong {
    background: rgba(244, 114, 182, 0.08);
    color: #fff;
  }

  @media (max-width: 780px) {
    .archive-filters {
      align-items: flex-start;
      flex-direction: column;
    }

    .archive-filters__chips {
      flex-wrap: nowrap;
      width: 100%;
      overflow-x: auto;
      padding-bottom: var(--s-1);
    }

    .archive-filters__tools {
      width: 100%;
    }
  }
</style>
