---
import type { PostEntry } from '../../lib/content';
import { getTagCounts, tagSlug } from '../../lib/content';

type Props = {
  posts: PostEntry[];
};

const { posts } = Astro.props;
const tags = getTagCounts(posts);
const total = posts.length;
---

<section class="archive-filters" aria-label="Archive filters">
  <div class="archive-filters__chips">
    <a class="tag-chip is-active" href="/posts/">all <small>{total}</small></a>
    {
      tags.map(([tag, count]) => (
        <a class="tag-chip" href={`/tags/${tagSlug(tag)}/`}>
          #{tag} <small>{count}</small>
        </a>
      ))
    }
  </div>
</section>

<style>
  .archive-filters {
    margin-bottom: var(--s-10);
  }

  .archive-filters__chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    align-items: center;
  }

  .tag-chip {
    padding: 5px 11px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.025);
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .tag-chip.is-active {
    border-color: rgba(244, 114, 182, 0.26);
    background: rgba(244, 114, 182, 0.08);
    color: var(--accent-pink);
  }

  .tag-chip small {
    color: var(--text-dim);
  }

  .tag-chip:hover {
    border-color: rgba(56, 189, 248, 0.24);
    color: var(--accent-blue);
  }

  @media (max-width: 780px) {
    .archive-filters__chips {
      flex-wrap: nowrap;
      width: 100%;
      overflow-x: auto;
      padding-bottom: var(--s-1);
    }
  }
</style>
