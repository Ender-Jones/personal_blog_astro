---
import type { PostEntry } from '../../lib/content';
import PinnedHero from './PinnedHero.astro';
import PostListRow from './PostListRow.astro';

type Props = {
  year: number;
  posts: PostEntry[];
  pinned?: PostEntry;
};

const { year, posts, pinned } = Astro.props;
const rows = pinned ? posts.filter((post) => post.id !== pinned.id) : posts;
const countLabel = `${posts.length} ${posts.length === 1 ? 'post' : 'posts'}`;
---

<section class="archive-year">
  <header class="archive-year__header">
    <h2>{year}</h2>
    <p>{countLabel}</p>
  </header>

  {pinned && <PinnedHero post={pinned} />}

  {
    rows.length > 0 && (
      <div class="archive-year__rows">
        {rows.map((post) => <PostListRow post={post} />)}
      </div>
    )
  }
</section>

<style>
  .archive-year {
    margin-top: var(--s-12);
  }

  .archive-year:first-child {
    margin-top: 0;
  }

  .archive-year__header {
    display: flex;
    align-items: baseline;
    gap: var(--s-4);
    margin-bottom: var(--s-5);
  }

  .archive-year__header h2 {
    margin: 0;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: clamp(34px, 6vw, 48px);
    font-weight: 300;
    line-height: 1;
  }

  .archive-year__header p {
    margin: 0;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .archive-year__header::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .archive-year__rows {
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    background: rgba(14, 16, 20, 0.82);
  }
</style>
