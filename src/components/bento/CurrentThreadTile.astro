---
import type { CurrentThread } from '../../lib/parseWorklog';
import { formatShortDate, worklogHref } from '../../lib/content';
import BentoTile from './BentoTile.astro';
import SectionLabel from '../ui/SectionLabel.astro';

type Props = {
  thread: CurrentThread;
};

const { thread } = Astro.props;
const hasThread = thread.state !== 'collapsed';
---

<BentoTile tone="blue">
  <div class="current-thread">
    {
      hasThread ? (
        <div class="current-thread__body">
          <div>
            <div class="current-thread__top">
              <SectionLabel tone="blue">Current Thread</SectionLabel>
              <a href={worklogHref(thread.worklog)}>open worklog</a>
            </div>
            <p class="current-thread__date">
              {formatShortDate(thread.updatedAt)} · {thread.state === 'stale' ? 'getting old' : 'recent'}
            </p>
            <h2>{thread.summary}</h2>
            {thread.bullets.length > 0 && (
              <ul>
                {thread.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
            )}
          </div>
          <div class="current-thread__bottom">
            {thread.state === 'stale' && <p class="current-thread__notice">thread is getting old</p>}
            <p class="current-thread__source">public thread summary · not raw notes</p>
          </div>
        </div>
      ) : (
        <div class="current-thread__body current-thread__body--collapsed">
          <SectionLabel>Current Thread</SectionLabel>
          <h2>No public thread set yet.</h2>
          <p>
            {thread.worklog
              ? `Last worklog: ${formatShortDate(thread.updatedAt ?? thread.worklog.data.date)}. Add a short public summary to surface it here.`
              : 'Add a worklog with a short public summary to surface it here.'}
          </p>
        </div>
      )
    }
  </div>
</BentoTile>

<style>
  .current-thread {
    height: 100%;
    min-height: 350px;
    background:
      radial-gradient(420px 280px at 100% 0%, rgba(56, 189, 248, 0.055), transparent 64%),
      rgba(14, 16, 20, 0.82);
  }

  .current-thread__body {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--s-5);
    padding: var(--s-6);
  }

  .current-thread__top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s-4);
  }

  .current-thread__top a,
  .current-thread__date,
  .current-thread__notice {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .current-thread__top a:hover {
    color: var(--accent-blue);
  }

  .current-thread h2 {
    margin: var(--s-5) 0;
    color: #fff;
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 400;
    line-height: 1.4;
  }

  .current-thread p {
    color: var(--text-muted);
    line-height: 1.7;
  }

  .current-thread ul {
    display: grid;
    gap: var(--s-3);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .current-thread li {
    color: #cfd5dd;
    font-size: 13px;
    line-height: 1.65;
  }

  .current-thread li::before {
    content: '›';
    margin-right: var(--s-3);
    color: var(--accent-blue);
    font-family: var(--font-mono);
  }

  .current-thread__notice {
    width: fit-content;
    padding: 7px 10px;
    border: 1px solid rgba(56, 189, 248, 0.16);
    border-radius: var(--r-sm);
    background: rgba(56, 189, 248, 0.05);
    color: var(--accent-blue);
  }

  .current-thread__bottom {
    display: grid;
    gap: var(--s-3);
    padding-top: var(--s-4);
    border-top: 1px dashed rgba(255, 255, 255, 0.06);
  }

  .current-thread__source {
    margin: 0;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 10px;
  }

  .current-thread__body--collapsed {
    justify-content: center;
  }

  @media (max-width: 560px) {
    .current-thread__top {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--s-2);
    }
  }
</style>
