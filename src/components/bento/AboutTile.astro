---
import BentoTile from './BentoTile.astro';
import SectionLabel from '../ui/SectionLabel.astro';
import { site } from '../../lib/data';
---

<BentoTile>
  <div class="about-tile">
    <img class="about-tile__avatar" src={site.avatar} alt="" aria-hidden="true" loading="lazy" />
    <SectionLabel>About</SectionLabel>
    <p>Who I am, what I work on, and how to reach me.</p>
    <a href="/about/">open</a>
  </div>
</BentoTile>

<style>
  .about-tile {
    position: relative;
    display: flex;
    height: 100%;
    min-height: 220px;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--s-5);
    padding: var(--s-6);
  }

  .about-tile p {
    margin: 0;
    color: var(--text-muted);
    font-size: 13px;
    line-height: 1.65;
  }

  .about-tile a {
    color: var(--accent-pink);
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .about-tile__avatar {
    position: absolute;
    right: var(--s-6);
    bottom: var(--s-6);
    width: 48px;
    height: 48px;
    border: 1px solid var(--border);
    border-radius: 50%;
    object-fit: cover;
    opacity: 0.28;
  }
</style>
