---
import type { PostEntry } from '../../lib/content';
import { formatDate, postHref } from '../../lib/content';
import BentoTile from './BentoTile.astro';

type Props = {
  posts: PostEntry[];
};

const { posts } = Astro.props;
const [leadPost, ...restPosts] = posts;
---

<BentoTile>
  <div class="recent-writing">
    <div class="recent-writing__header">
      <div>
        <h2>Recent Writing</h2>
        <p>{posts.length} latest entries</p>
      </div>
      <a href="/posts/">all posts</a>
    </div>

    <div class="recent-writing__body">
      {
        leadPost && (
          <a class="recent-writing__lead" href={postHref(leadPost)}>
            {leadPost.data.image && (
              <img src={leadPost.data.image} alt={leadPost.data.image_alt ?? ''} loading="lazy" />
            )}
            <span class="recent-writing__lead-body">
              <small>
                {[formatDate(leadPost.data.date), ...leadPost.data.tags.slice(0, 2).map((tag) => `#${tag}`)].join(
                  ' · ',
                )}
              </small>
              <strong>{leadPost.data.title}</strong>
              {leadPost.data.description && <em>{leadPost.data.description}</em>}
            </span>
          </a>
        )
      }

      <div class="recent-writing__list">
        {
          restPosts.map((post) => (
            <a class="recent-writing__item" href={postHref(post)}>
              {post.data.image && (
                <img src={post.data.image} alt={post.data.image_alt ?? ''} loading="lazy" />
              )}
              <span>
                <strong>{post.data.title}</strong>
                <small>
                  {[formatDate(post.data.date), ...post.data.tags.slice(0, 2).map((tag) => `#${tag}`)].join(' · ')}
                </small>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</BentoTile>

<style>
  .recent-writing {
    padding: var(--s-6);
  }

  .recent-writing__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s-4);
    margin-bottom: var(--s-4);
  }

  .recent-writing h2 {
    margin: 0;
    color: #fff;
    font-size: 24px;
  }

  .recent-writing p,
  .recent-writing__header a {
    margin: var(--s-2) 0 0;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .recent-writing__header a:hover {
    color: var(--accent-blue);
  }

  .recent-writing__body {
    display: grid;
    grid-template-columns: minmax(220px, 0.9fr) minmax(0, 1.1fr);
    gap: var(--s-5);
  }

  .recent-writing__lead {
    position: relative;
    display: flex;
    min-height: 286px;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    background: rgba(7, 8, 9, 0.74);
  }

  .recent-writing__lead img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.68) saturate(0.9);
    transition: transform 180ms ease;
  }

  .recent-writing__lead::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 20%, rgba(7, 8, 9, 0.96) 92%);
  }

  .recent-writing__lead-body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: var(--s-3);
    width: 100%;
    padding: var(--s-5);
  }

  .recent-writing__lead strong {
    color: #fff;
    font-size: clamp(22px, 3vw, 30px);
    line-height: 1.12;
  }

  .recent-writing__lead small,
  .recent-writing__lead em {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 11px;
    font-style: normal;
    line-height: 1.55;
  }

  .recent-writing__lead em {
    max-width: 34ch;
    font-family: var(--font-sans);
    font-size: 13px;
  }

  .recent-writing__list {
    display: grid;
    align-content: start;
  }

  .recent-writing__item {
    display: grid;
    grid-template-columns: 68px 1fr;
    gap: var(--s-4);
    align-items: center;
    padding: var(--s-4) 0;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  .recent-writing__item img {
    width: 68px;
    height: 58px;
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    object-fit: cover;
    filter: brightness(0.86) saturate(0.92);
  }

  .recent-writing__item strong {
    display: block;
    overflow: hidden;
    color: #fff;
    font-size: 15px;
    line-height: 1.35;
  }

  .recent-writing__item small {
    display: block;
    margin-top: var(--s-2);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 10px;
  }

  @media (hover: hover) and (pointer: fine) {
    .recent-writing__lead:hover img {
      transform: scale(1.035);
    }
  }

  @media (max-width: 820px) {
    .recent-writing__body {
      grid-template-columns: 1fr;
    }

    .recent-writing__lead {
      min-height: 260px;
    }
  }

  @media (max-width: 560px) {
    .recent-writing__header {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--s-2);
    }

    .recent-writing__item {
      grid-template-columns: 56px 1fr;
    }

    .recent-writing__item img {
      width: 56px;
      height: 52px;
    }

    .recent-writing__lead {
      min-height: 232px;
    }

    .recent-writing__lead-body {
      padding: var(--s-4);
    }
  }
</style>
