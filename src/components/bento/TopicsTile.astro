---
import type { PostEntry } from '../../lib/content';
import { getTagCounts, tagSlug } from '../../lib/content';
import BentoTile from './BentoTile.astro';
import SectionLabel from '../ui/SectionLabel.astro';

type Props = {
  posts: PostEntry[];
};

const { posts } = Astro.props;
const tags = getTagCounts(posts).slice(0, 10);
---

<BentoTile>
  <div class="topics-tile">
    <div class="topics-tile__top">
      <SectionLabel>Browse by topic</SectionLabel>
      <a href="/tags/">all tags</a>
    </div>

    <div class="topics-tile__cloud">
      {
        tags.map(([tag, count]) => (
          <a href={`/tags/${tagSlug(tag)}/`}>
            #{tag} <small>{count}</small>
          </a>
        ))
      }
    </div>
  </div>
</BentoTile>

<style>
  .topics-tile {
    padding: var(--s-6);
  }

  .topics-tile__top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s-4);
    margin-bottom: var(--s-5);
  }

  .topics-tile__top a {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .topics-tile__cloud {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
  }

  .topics-tile__cloud a {
    padding: 5px 10px;
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    background: rgba(255, 255, 255, 0.025);
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .topics-tile__cloud a:hover {
    color: var(--accent-blue);
  }

  .topics-tile small {
    color: var(--text-dim);
  }
</style>
