---
import BentoTile from './BentoTile.astro';
import SectionLabel from '../ui/SectionLabel.astro';
import { site } from '../../lib/data';
---

<BentoTile tone="blue">
  <div class="github-tile">
    <SectionLabel tone="blue">GitHub</SectionLabel>
    <p>Code, experiments, and small tools.</p>
    {site.socials.github && <a href={site.socials.github}>open profile</a>}
  </div>
</BentoTile>

<style>
  .github-tile {
    display: flex;
    height: 100%;
    min-height: 190px;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--s-5);
    padding: var(--s-6);
  }

  .github-tile p {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.65;
  }

  .github-tile a {
    color: var(--accent-blue);
    font-family: var(--font-mono);
    font-size: 12px;
  }
</style>
