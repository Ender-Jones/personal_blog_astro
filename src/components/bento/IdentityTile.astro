---
import BentoTile from './BentoTile.astro';
import SectionLabel from '../ui/SectionLabel.astro';
import { site } from '../../lib/data';

const socials = [
  ['github', site.socials.github],
  ['x', site.socials.twitter],
  ['email', site.socials.email],
].filter((item): item is [string, string] => Boolean(item[1]));
---

<BentoTile class="identity-tile" tone="pink">
  <img class="identity-tile__image" src={site.avatar} alt={`${site.name} portrait`} />
  <div class="identity-tile__shade"></div>
  <div class="identity-tile__body">
    <SectionLabel tone="pink">The author</SectionLabel>
    <h2>{site.name}</h2>
    <p>{site.role} · {site.location}</p>
    <div class="identity-tile__links">
      {socials.map(([label, href]) => <a href={href}>{label}</a>)}
    </div>
  </div>
</BentoTile>

<style>
  .identity-tile {
    min-height: 260px;
  }

  .identity-tile__image,
  .identity-tile__shade {
    position: absolute;
    inset: 0;
  }

  .identity-tile__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.88) saturate(0.95);
  }

  .identity-tile__shade {
    background: linear-gradient(180deg, transparent 20%, rgba(7, 8, 9, 0.96) 88%);
  }

  .identity-tile__body {
    position: absolute;
    right: var(--s-6);
    bottom: var(--s-6);
    left: var(--s-6);
  }

  .identity-tile h2 {
    margin: var(--s-3) 0 var(--s-2);
    color: #fff;
    font-size: 26px;
    line-height: 1.1;
  }

  .identity-tile p {
    margin: 0 0 var(--s-4);
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .identity-tile__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
  }

  .identity-tile__links a {
    padding: 4px 10px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    background: rgba(7, 8, 9, 0.5);
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 11px;
  }
</style>
