---
import type { QuoteData } from '../../lib/data';
import BentoTile from './BentoTile.astro';
import SectionLabel from '../ui/SectionLabel.astro';

type Props = {
  quote: QuoteData;
};

const { quote } = Astro.props;
---

<BentoTile class="marginalia-tile" tone="pink">
  <SectionLabel tone="pink">Marginalia</SectionLabel>
  <blockquote>
    <p>{quote.text}</p>
    <footer>
      {quote.source}{quote.work ? ` · ${quote.work}` : ''}{quote.year ? ` · ${quote.year}` : ''}
    </footer>
  </blockquote>
</BentoTile>

<style>
  .marginalia-tile {
    min-height: 190px;
    padding: var(--s-6);
  }

  .marginalia-tile blockquote {
    margin: var(--s-5) 0 0;
    padding-left: var(--s-4);
    border-left: 3px solid var(--accent-pink);
  }

  .marginalia-tile p {
    margin: 0;
    color: #d4d8de;
    font-family: var(--font-serif);
    font-size: 17px;
    font-style: italic;
    line-height: 1.6;
  }

  .marginalia-tile footer {
    margin-top: var(--s-4);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 11px;
  }
</style>
