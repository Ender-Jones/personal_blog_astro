---
import { getCollection, type CollectionEntry } from 'astro:content';
import ArchiveShell from '../../components/archive/ArchiveShell.astro';
import PostListRow from '../../components/archive/PostListRow.astro';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { byDateDesc, getTagCounts, tagSlug } from '../../lib/content';
import { getCurrentThread, type CurrentThread } from '../../lib/parseWorklog';

export async function getStaticPaths() {
  const posts = byDateDesc(await getCollection('posts'));
  const currentThread = getCurrentThread(await getCollection('worklogs'));
  const tags = getTagCounts(posts);

  return tags.map(([tag]) => ({
    params: { tag: tagSlug(tag) },
    props: {
      tag,
      posts: posts.filter((post) => post.data.tags.some((postTag) => tagSlug(postTag) === tagSlug(tag))),
      tags,
      currentThread,
    },
  }));
}

type Props = {
  tag: string;
  posts: CollectionEntry<'posts'>[];
  tags: [string, number][];
  currentThread?: CurrentThread;
};

const { tag, posts, tags, currentThread } = Astro.props;
const title = `#${tag}`;
---

<BaseLayout title={title} description={`Posts tagged ${tag}.`}>
  <ArchiveShell currentThread={currentThread}>
    <section class="route-header tag-page__header">
      <p class="eyebrow">/ tags</p>
      <h1>{title}</h1>
      <p>{posts.length} {posts.length === 1 ? 'post' : 'posts'} filed under this topic.</p>
      <div class="tag-page__links">
        <a href="/tags/">all topics</a>
        <a href="/posts/">all writing</a>
      </div>
    </section>

    <nav class="tag-page__topics" aria-label="Other topics">
      {
        tags.map(([topic, count]) => (
          <a class={topic === tag ? 'is-active' : ''} href={`/tags/${tagSlug(topic)}/`}>
            #{topic} <small>{count}</small>
          </a>
        ))
      }
    </nav>

    <div class="tag-page__posts surface-panel">
      {posts.map((post) => <PostListRow post={post} />)}
    </div>
  </ArchiveShell>
</BaseLayout>

<style>
  .tag-page__header {
    position: relative;
  }

  .tag-page__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-3);
    margin-top: var(--s-4);
  }

  .tag-page__links a {
    color: var(--accent-blue);
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .tag-page__topics {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    margin-bottom: var(--s-8);
  }

  .tag-page__topics a {
    padding: 5px 11px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.025);
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .tag-page__topics a.is-active {
    border-color: rgba(244, 114, 182, 0.26);
    background: rgba(244, 114, 182, 0.08);
    color: var(--accent-pink);
  }

  .tag-page__topics small {
    color: var(--text-dim);
  }

  .tag-page__posts {
    overflow: hidden;
  }

  .tag-page__header h1 {
    overflow-wrap: anywhere;
    font-size: clamp(48px, 7vw, 76px);
  }

  @media (max-width: 780px) {
    .tag-page__topics {
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-bottom: var(--s-1);
    }

    .tag-page__topics a {
      flex: 0 0 auto;
    }
  }
</style>
