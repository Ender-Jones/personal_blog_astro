---
import { getCollection } from 'astro:content';
import ArchiveShell from '../../components/archive/ArchiveShell.astro';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { getTagCounts, tagSlug } from '../../lib/content';
import { getCurrentThread } from '../../lib/parseWorklog';

const posts = await getCollection('posts');
const tags = getTagCounts(posts);
const currentThread = getCurrentThread(await getCollection('worklogs'));
---

<BaseLayout title="Tags" description="Topic index for EnderJones writing.">
  <ArchiveShell currentThread={currentThread}>
    <section class="route-header tag-index__header">
      <p class="eyebrow">/ tags</p>
      <h1>Topics</h1>
      <p>{tags.length} tags across {posts.length} posts.</p>
    </section>

    <div class="tag-cloud surface-panel">
      {
        tags.map(([tag, count]) => (
          <a class="tag-chip" href={`/tags/${tagSlug(tag)}/`}>
            <strong>#{tag}</strong>
            <small>{count} {count === 1 ? 'post' : 'posts'}</small>
          </a>
        ))
      }
    </div>
  </ArchiveShell>
</BaseLayout>

<style>
  .tag-index__header h1 {
    font-size: clamp(48px, 7vw, 76px);
  }

  .tag-cloud {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--s-3);
    padding: var(--s-6);
  }

  .tag-chip {
    display: grid;
    min-height: 92px;
    align-content: space-between;
    padding: var(--s-4);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    color: var(--text-muted);
    font-family: var(--font-mono);
    background: rgba(255, 255, 255, 0.025);
  }

  .tag-chip strong {
    overflow-wrap: anywhere;
    color: #fff;
    font-family: var(--font-sans);
    font-size: 18px;
    line-height: 1.2;
  }

  .tag-chip:hover {
    border-color: rgba(56, 189, 248, 0.26);
    color: var(--accent-blue);
  }

  .tag-chip small {
    color: var(--text-dim);
    font-size: 11px;
  }

  @media (max-width: 760px) {
    .tag-cloud {
      grid-template-columns: 1fr;
      padding: var(--s-4);
    }

    .tag-chip {
      min-height: 76px;
    }
  }
</style>
