---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import AuthorRail from '../../components/author/AuthorRail.astro';
import AuthorStrip from '../../components/author/AuthorStrip.astro';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import PostHeader from '../../components/post/PostHeader.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');

  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

type Props = {
  post: CollectionEntry<'posts'>;
};

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <main class="post-page">
    <PostHeader post={post} />
    <div class="read-layout">
      <div class="read-layout__rail">
        <AuthorRail />
      </div>
      <article class="read-layout__body prose">
        <Content />
      </article>
    </div>
    <AuthorStrip />
  </main>
</BaseLayout>

<style>
  .post-page {
    padding-bottom: var(--s-20);
  }
</style>
