---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { formatDate } from '../../lib/content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');

  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

type Props = {
  post: CollectionEntry<'posts'>;
};

const { post } = Astro.props;
const { Content } = await render(post);

const coverMode =
  post.data.cover_mode ?? (post.data.image ? (post.data.pinned ? 'hero-large' : 'hero-small') : 'none');

const hasImage = Boolean(post.data.image && coverMode !== 'none');
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <main class={`post-page post-page--${coverMode}`} style={`--post-image-focus: ${post.data.image_focus};`}>
    <header class="post-header">
      {hasImage && coverMode !== 'showcase' && <img src={post.data.image} alt="" aria-hidden="true" />}
      <div class="post-header__body">
        <p class="eyebrow">{post.data.pinned ? 'Pinned Essay' : 'Writing'} · {formatDate(post.data.date)}</p>
        <h1>{post.data.title}</h1>
        {post.data.description && <p>{post.data.description}</p>}
        <div class="post-header__tags">
          {post.data.tags.map((tag) => <span>#{tag}</span>)}
        </div>
      </div>
    </header>

    {
      hasImage && coverMode === 'showcase' && (
        <figure class="post-showcase">
          <img src={post.data.image} alt={post.data.image_alt ?? post.data.title} />
          {post.data.image_alt && <figcaption>{post.data.image_alt}</figcaption>}
        </figure>
      )
    }

    <article class="post-body prose">
      <Content />
    </article>
  </main>
</BaseLayout>

<style>
  .post-page {
    padding-bottom: var(--s-20);
  }

  .post-header {
    position: relative;
    overflow: hidden;
    min-height: 320px;
  }

  .post-page--none .post-header,
  .post-page--showcase .post-header {
    min-height: 0;
  }

  .post-page--strip .post-header {
    min-height: 220px;
  }

  .post-header > img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--post-image-focus, 50% 50%);
    filter: brightness(0.68) saturate(0.92);
  }

  .post-page--strip .post-header > img {
    filter: brightness(0.48) saturate(0.85) blur(2px);
  }

  .post-header::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(7, 8, 9, 0.2), rgba(7, 8, 9, 0.95));
  }

  .post-page--none .post-header::after,
  .post-page--showcase .post-header::after {
    content: none;
  }

  .post-header__body {
    position: relative;
    z-index: 1;
    width: min(860px, calc(100% - 40px));
    margin: 0 auto;
    padding: var(--s-16) 0 var(--s-10);
  }

  .post-page--hero-large .post-header__body {
    padding-top: 220px;
  }

  .post-header h1 {
    max-width: 860px;
    margin: var(--s-4) 0;
    color: #fff;
    font-size: clamp(40px, 7vw, 64px);
    line-height: 1.1;
  }

  .post-header__body > p:not(.eyebrow) {
    max-width: 720px;
    margin: 0;
    color: var(--text-muted);
    font-size: 17px;
    line-height: 1.65;
  }

  .post-header__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    margin-top: var(--s-5);
  }

  .post-header__tags span {
    padding: 3px 8px;
    border-radius: var(--r-sm);
    background: rgba(255, 255, 255, 0.05);
    color: #cfd5dd;
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .post-showcase {
    width: min(960px, calc(100% - 40px));
    margin: 0 auto var(--s-12);
  }

  .post-showcase img {
    width: 100%;
    max-height: 560px;
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    object-fit: contain;
    background: var(--surface);
  }

  .post-showcase figcaption {
    margin-top: var(--s-3);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 11px;
    text-align: center;
  }

  .post-body {
    width: min(720px, calc(100% - 40px));
    margin: 0 auto;
  }
</style>
