---
import { getCollection } from 'astro:content';
import BaseLayout from '../components/layout/BaseLayout.astro';
import { byDateDesc, formatDate, postHref } from '../lib/content';
import { research, site } from '../lib/data';

const posts = byDateDesc(await getCollection('posts'));
const featuredPost = posts.find((post) => post.data.pinned) ?? posts[0];
const selectedPosts = posts.filter((post) => post.id !== featuredPost?.id).slice(0, 3);

const socials = [
  ['GitHub', 'Ender-Jones', site.socials.github],
  ['X', '@EnderJones1872', site.socials.twitter],
  ['Email', site.socials.email?.replace('mailto:', ''), site.socials.email],
].filter(([, , href]) => Boolean(href));
---

<BaseLayout title="About" description={site.research_oneliner}>
  <main class="about-page">
    <section class="about-hero">
      <div class="about-hero__portrait">
        <img src={site.avatar} alt={`${site.name} avatar`} />
      </div>
      <div class="about-hero__body">
        <p class="eyebrow">/ about</p>
        <h1>{site.name}</h1>
        <p class="about-hero__meta">{site.role} · {site.location}</p>
        <p class="about-hero__lead">
          I keep this site as a research notebook, personal archive, and proof that I am still working.
        </p>
        <div class="about-hero__links" aria-label="Contact links">
          {socials.map(([label, value, href]) => <a href={href}>{label}<span>{value}</span></a>)}
        </div>
      </div>
    </section>

    <section class="about-grid">
      <article class="about-panel about-panel--research">
        <p class="eyebrow">Research · Now</p>
        <h2>{research.focus}</h2>
        <p>{research.abstract}</p>
        <div class="about-tags">
          {research.tags.map((tag) => <span>{tag}</span>)}
        </div>
      </article>

      {
        featuredPost && (
          <article class="about-panel about-panel--featured">
            {featuredPost.data.image && <img src={featuredPost.data.image} alt="" aria-hidden="true" />}
            <div>
              <p class="eyebrow">Personal entry</p>
              <h2>{featuredPost.data.title}</h2>
              {featuredPost.data.description && <p>{featuredPost.data.description}</p>}
              <a href={postHref(featuredPost)}>read the pinned essay</a>
            </div>
          </article>
        )
      }

      <article class="about-panel about-panel--writing">
        <p class="eyebrow">Writing</p>
        <h2>Recent notes</h2>
        <div class="about-writing-list">
          {
            selectedPosts.map((post) => (
              <a href={postHref(post)}>
                <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
                <strong>{post.data.title}</strong>
              </a>
            ))
          }
        </div>
      </article>

      <article class="about-panel about-panel--site">
        <p class="eyebrow">This site</p>
        <dl>
          <div>
            <dt>Posts</dt>
            <dd>{posts.length}</dd>
          </div>
          <div>
            <dt>Primary mode</dt>
            <dd>Markdown-first writing</dd>
          </div>
          <div>
            <dt>Private notes</dt>
            <dd>Excluded from build</dd>
          </div>
        </dl>
      </article>
    </section>
  </main>
</BaseLayout>

<style>
  .about-page {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
    padding: var(--s-16) 0 var(--s-20);
  }

  .about-hero {
    display: grid;
    grid-template-columns: minmax(220px, 0.42fr) minmax(0, 1fr);
    gap: clamp(var(--s-8), 6vw, var(--s-16));
    align-items: center;
    min-height: 520px;
    padding-bottom: var(--s-12);
  }

  .about-hero__portrait {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    background: rgba(14, 16, 20, 0.72);
  }

  .about-hero__portrait::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 45%, rgba(7, 8, 9, 0.62));
  }

  .about-hero__portrait img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  .about-hero h1 {
    max-width: 720px;
    margin: var(--s-4) 0;
    color: #fff;
    font-size: clamp(56px, 9vw, 104px);
    line-height: 0.95;
  }

  .about-hero__meta {
    margin: 0;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 14px;
  }

  .about-hero__lead {
    max-width: 720px;
    margin: var(--s-8) 0 0;
    color: #dfe4ea;
    font-size: clamp(22px, 3vw, 32px);
    line-height: 1.35;
  }

  .about-hero__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-3);
    margin-top: var(--s-8);
  }

  .about-hero__links a {
    display: grid;
    gap: var(--s-1);
    min-width: 150px;
    padding: var(--s-3) var(--s-4);
    border: 1px solid var(--border-hi);
    border-radius: var(--r-md);
    background: rgba(255, 255, 255, 0.03);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .about-hero__links span {
    overflow: hidden;
    color: var(--accent-blue);
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.7fr);
    gap: var(--s-5);
  }

  .about-panel {
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    background: rgba(14, 16, 20, 0.78);
  }

  .about-panel:not(.about-panel--featured) {
    padding: clamp(var(--s-5), 3vw, var(--s-8));
  }

  .about-panel h2 {
    margin: var(--s-4) 0;
    color: #fff;
    font-size: clamp(26px, 4vw, 38px);
    line-height: 1.18;
  }

  .about-panel p:not(.eyebrow) {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .about-tags,
  .about-writing-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    margin-top: var(--s-6);
  }

  .about-tags span {
    padding: 5px 10px;
    border: 1px solid rgba(52, 211, 153, 0.18);
    border-radius: 999px;
    color: #cfd5dd;
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .about-panel--research {
    grid-row: span 2;
  }

  .about-panel--featured {
    display: grid;
    overflow: hidden;
  }

  .about-panel--featured img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    filter: brightness(0.78) saturate(0.9);
  }

  .about-panel--featured div {
    padding: var(--s-6);
  }

  .about-panel--featured a {
    display: inline-flex;
    margin-top: var(--s-5);
    color: var(--accent-pink);
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .about-writing-list {
    display: grid;
  }

  .about-writing-list a {
    display: grid;
    gap: var(--s-2);
    padding: var(--s-4) 0;
    border-top: 1px solid var(--border);
  }

  .about-writing-list time {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .about-writing-list strong {
    color: #fff;
    font-size: 16px;
    line-height: 1.35;
  }

  .about-panel--site dl {
    display: grid;
    gap: var(--s-3);
    margin: var(--s-5) 0 0;
  }

  .about-panel--site div {
    display: flex;
    justify-content: space-between;
    gap: var(--s-4);
    border-top: 1px solid var(--border);
    padding-top: var(--s-3);
  }

  .about-panel--site dt,
  .about-panel--site dd {
    margin: 0;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .about-panel--site dd {
    color: #fff;
    text-align: right;
  }

  @media (max-width: 860px) {
    .about-page {
      width: min(760px, calc(100% - 32px));
      padding-top: var(--s-10);
    }

    .about-hero,
    .about-grid {
      grid-template-columns: 1fr;
    }

    .about-hero {
      gap: var(--s-8);
      min-height: 0;
      padding-bottom: var(--s-10);
    }

    .about-hero__portrait {
      max-width: 320px;
    }

    .about-hero__lead {
      font-size: 22px;
    }

    .about-panel:not(.about-panel--featured) {
      padding: var(--s-5);
    }
  }

  @media (max-width: 520px) {
    .about-hero__links {
      display: grid;
    }

    .about-hero__links a {
      min-width: 0;
    }
  }
</style>
