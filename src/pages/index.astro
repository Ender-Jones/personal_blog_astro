---
import { getCollection } from 'astro:content';
import AboutTile from '../components/bento/AboutTile.astro';
import CurrentThreadTile from '../components/bento/CurrentThreadTile.astro';
import GithubTile from '../components/bento/GithubTile.astro';
import IdentityTile from '../components/bento/IdentityTile.astro';
import MarginaliaTile from '../components/bento/MarginaliaTile.astro';
import RecentWritingTile from '../components/bento/RecentWritingTile.astro';
import ResearchNowTile from '../components/bento/ResearchNowTile.astro';
import SelectedEntryTile from '../components/bento/SelectedEntryTile.astro';
import TopicsTile from '../components/bento/TopicsTile.astro';
import BaseLayout from '../components/layout/BaseLayout.astro';
import { getCurrentThread } from '../lib/parseWorklog';
import { resolveSelectedEntry } from '../lib/selectEntry';
import { byDateDesc } from '../lib/content';
import { quotes, research, site } from '../lib/data';

const posts = await getCollection('posts');
const worklogs = await getCollection('worklogs');
const recentPosts = byDateDesc(posts).slice(0, 4);
const currentThread = getCurrentThread(worklogs);
const selectedEntry = resolveSelectedEntry(posts);
const quote = quotes[new Date().getUTCDate() % quotes.length];
const threadStateLabel =
  currentThread.state === 'collapsed' ? 'quiet' : currentThread.state === 'stale' ? 'stale' : 'fresh';
---

<BaseLayout title={site.name} description={site.research_oneliner}>
  <main class="home-page">
    <header class="home-intro">
      <div class="home-intro__copy">
        <div class="home-intro__line">
          <span></span>
          <p class="eyebrow">Personal Archive · Est. 2025</p>
        </div>
        <h1>
          {site.name}<span class="blink-cursor" aria-hidden="true">_</span>
        </h1>
        <p>
          {site.role} in Tokyo, researching {research.focus.toLowerCase()}
          This is my notebook: essays, research notes, and an append-only worklog.
        </p>
      </div>

      <aside class="home-intro__signal" aria-label="Site signals">
        <p class="eyebrow">Now</p>
        <strong>{research.focus}</strong>
        <dl>
          <div>
            <dt>writing</dt>
            <dd>{posts.length} posts</dd>
          </div>
          <div>
            <dt>worklog</dt>
            <dd>{worklogs.length} months</dd>
          </div>
          <div>
            <dt>thread</dt>
            <dd>{threadStateLabel}</dd>
          </div>
        </dl>
      </aside>
    </header>

    <div class="bento-grid">
      <div class="bento-grid__identity"><IdentityTile /></div>
      <div class="bento-grid__research"><ResearchNowTile /></div>
      <div class="bento-grid__recent"><RecentWritingTile posts={recentPosts} /></div>
      <div class="bento-grid__thread"><CurrentThreadTile thread={currentThread} /></div>
      <div class="bento-grid__selected"><SelectedEntryTile selected={selectedEntry} /></div>
      <div class="bento-grid__topics"><TopicsTile posts={posts} /></div>
      <div class="bento-grid__about"><AboutTile /></div>
      {quote && <div class="bento-grid__marginalia"><MarginaliaTile quote={quote} /></div>}
      <div class="bento-grid__github"><GithubTile /></div>
    </div>
  </main>
</BaseLayout>

<style>
  .home-page {
    width: min(1312px, calc(100% - 40px));
    margin: 0 auto;
    padding: var(--s-12) 0 var(--s-20);
  }

  .home-intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
    gap: clamp(var(--s-6), 6vw, var(--s-16));
    align-items: end;
    padding: var(--s-10) 0 var(--s-8);
  }

  .home-intro__line {
    display: flex;
    align-items: center;
    gap: var(--s-3);
    margin-bottom: var(--s-5);
  }

  .home-intro__line span {
    width: 24px;
    height: 1px;
    background: var(--accent-pink);
  }

  .home-intro h1 {
    margin: 0;
    color: #fff;
    font-size: clamp(48px, 9vw, 112px);
    line-height: 0.92;
  }

  .home-intro p:not(.eyebrow) {
    max-width: 760px;
    margin: var(--s-5) 0 0;
    color: #cfd5dd;
    font-size: clamp(16px, 2vw, 19px);
    line-height: 1.68;
  }

  .home-intro__signal {
    padding: var(--s-5);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), transparent),
      rgba(14, 16, 20, 0.72);
  }

  .home-intro__signal strong {
    display: block;
    margin-top: var(--s-4);
    color: #fff;
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.35;
  }

  .home-intro__signal dl {
    display: grid;
    gap: var(--s-3);
    margin: var(--s-5) 0 0;
  }

  .home-intro__signal div {
    display: flex;
    justify-content: space-between;
    gap: var(--s-4);
    padding-top: var(--s-3);
    border-top: 1px solid var(--border);
  }

  .home-intro__signal dt,
  .home-intro__signal dd {
    margin: 0;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .home-intro__signal dd {
    color: var(--accent-blue);
    text-align: right;
  }

  .bento-grid {
    display: grid;
    grid-auto-rows: minmax(112px, auto);
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 14px;
  }

  .bento-grid > div {
    min-width: 0;
  }

  .bento-grid__identity {
    grid-column: span 4;
    grid-row: span 2;
  }

  .bento-grid__research {
    grid-column: span 8;
    grid-row: span 2;
  }

  .bento-grid__recent {
    grid-column: span 7;
    grid-row: span 3;
  }

  .bento-grid__thread {
    grid-column: span 5;
    grid-row: span 3;
  }

  .bento-grid__selected {
    grid-column: span 5;
    grid-row: span 2;
  }

  .bento-grid__topics {
    grid-column: span 4;
    grid-row: span 2;
  }

  .bento-grid__about {
    grid-column: span 3;
    grid-row: span 2;
  }

  .bento-grid__marginalia {
    grid-column: span 6;
  }

  .bento-grid__github {
    grid-column: span 6;
  }

  @media (max-width: 1020px) {
    .home-intro {
      grid-template-columns: 1fr;
      align-items: stretch;
      padding-top: var(--s-8);
    }

    .home-intro__signal {
      max-width: 520px;
    }

    .bento-grid {
      grid-template-columns: repeat(6, minmax(0, 1fr));
    }

    .bento-grid > div {
      grid-column: span 6;
      grid-row: auto;
    }
  }

  @media (max-width: 560px) {
    .home-page {
      width: min(100% - 28px, 1312px);
      padding-top: var(--s-8);
    }

    .home-intro {
      gap: var(--s-6);
    }

    .home-intro h1 {
      font-size: clamp(44px, 15vw, 64px);
    }

    .bento-grid {
      gap: var(--s-3);
    }
  }
</style>
