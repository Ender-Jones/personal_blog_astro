---
import { getCollection } from 'astro:content';
import ActivityEvidence from '../components/home/ActivityEvidence.astro';
import CurrentThreadCompact from '../components/home/CurrentThreadCompact.astro';
import HeroSection from '../components/home/HeroSection.astro';
import PersonalityContact from '../components/home/PersonalityContact.astro';
import ResearchNowCard from '../components/home/ResearchNowCard.astro';
import WritingSurface from '../components/home/WritingSurface.astro';
import BaseLayout from '../components/layout/BaseLayout.astro';
import { byDateDesc, type PostEntry } from '../lib/content';
import { quotes, research, site } from '../lib/data';
import { getCurrentThread } from '../lib/parseWorklog';

type FeaturedSource = 'selected' | 'pinned' | 'latest' | 'startHere';

const posts = byDateDesc(await getCollection('posts'));
const worklogs = await getCollection('worklogs');
const currentThread = getCurrentThread(worklogs);
const featured = resolveFeaturedPost(posts);
const quote = quotes[new Date().getUTCDate() % quotes.length];
const latestWorklog = byDateDesc(worklogs)[0];
const archiveMeta = [
  `${posts.length} posts`,
  latestWorklog ? `${worklogs.length} worklogs` : 'worklog quiet',
  latestWorklog ? formatMetaDate(latestWorklog.data.updated ?? latestWorklog.data.date) : 'no active month',
].join(' · ');

function resolveFeaturedPost(items: PostEntry[]): { post: PostEntry | null; source: FeaturedSource } {
  const selected = items.find((post) => post.data.selected);
  if (selected) return { post: selected, source: 'selected' };

  const pinned = items.find((post) => post.data.pinned);
  if (pinned) return { post: pinned, source: 'pinned' };

  const latest = items[0];
  if (latest) return { post: latest, source: 'latest' };

  const whoAmI = items.find((post) => post.id === 'who-am-i');
  if (whoAmI) return { post: whoAmI, source: 'startHere' };

  return { post: null, source: 'latest' };
}

function formatMetaDate(date: Date) {
  return new Intl.DateTimeFormat('en-CA', {
    timeZone: 'Asia/Tokyo',
    year: 'numeric',
    month: '2-digit',
  }).format(date);
}
---

<BaseLayout title={site.name} description={site.research_oneliner}>
  <main class="home-page">
    <div class="home-archive-strip">
      <span></span>
      <p>Personal Archive · No. 01 · Est. 2025 · Tokyo</p>
      <i></i>
      <small>{archiveMeta}</small>
    </div>

    <section class="home-first" aria-label="First impression">
      <HeroSection site={site} />

      <div class="home-first__support">
        <ResearchNowCard research={research} />
        <CurrentThreadCompact thread={currentThread} />
      </div>
    </section>

    <WritingSurface featured={featured.post} posts={posts} source={featured.source} />

    <ActivityEvidence thread={currentThread} posts={posts} site={site} />

    <PersonalityContact quote={quote} site={site} />
  </main>
</BaseLayout>

<style>
  .home-page {
    display: grid;
    gap: 56px;
    width: min(1272px, calc(100% - 40px));
    margin: 0 auto;
    padding: var(--s-8) 0 var(--s-20);
  }

  .home-archive-strip {
    display: flex;
    align-items: center;
    gap: var(--s-3);
    margin-top: var(--s-2);
  }

  .home-archive-strip span {
    width: 24px;
    height: 1px;
    background: var(--accent-pink);
  }

  .home-archive-strip i {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(244, 114, 182, 0.22), transparent);
  }

  .home-archive-strip p,
  .home-archive-strip small {
    margin: 0;
    color: var(--accent-pink);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .home-archive-strip small {
    color: var(--text-dim);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: none;
  }

  .home-first {
    display: grid;
    grid-auto-rows: 256px;
    grid-template-columns: minmax(0, 1.65fr) minmax(320px, 1fr);
    gap: var(--s-4);
    align-items: stretch;
  }

  .home-first__support {
    display: grid;
    grid-row: span 2;
    grid-template-rows: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--s-4);
  }

  .home-first > :first-child {
    grid-row: span 2;
  }

  @media (max-width: 1060px) {
    .home-page {
      width: min(100% - 32px, 760px);
      gap: var(--s-12);
    }

    .home-first {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
    }

    .home-first__support {
      grid-row: auto;
      grid-template-rows: auto;
    }

    .home-first > :first-child {
      grid-row: auto;
    }
  }

  @media (max-width: 560px) {
    .home-page {
      width: min(100% - 28px, 1272px);
      gap: var(--s-10);
      padding-top: var(--s-6);
    }

    .home-archive-strip {
      align-items: flex-start;
      flex-direction: column;
    }

    .home-archive-strip i {
      width: 100%;
      flex: none;
    }
  }
</style>
