---
import { getCollection } from 'astro:content';
import ActivityEvidence from '../components/home/ActivityEvidence.astro';
import HeroSection from '../components/home/HeroSection.astro';
import PersonalityContact from '../components/home/PersonalityContact.astro';
import WritingSurface from '../components/home/WritingSurface.astro';
import BaseLayout from '../components/layout/BaseLayout.astro';
import SectionMarker from '../components/ui/SectionMarker.astro';
import { byDateDesc } from '../lib/content';
import { site } from '../lib/data';
import { getRandomMarginalia } from '../lib/marginalia';
import { getCurrentThread } from '../lib/parseWorklog';

const posts = byDateDesc(await getCollection('posts'));
const worklogs = await getCollection('worklogs');
const currentThread = getCurrentThread(worklogs);
const marginalia = getRandomMarginalia(posts);
---

<BaseLayout title={site.name} description={site.research_oneliner}>
  <main class="home-page">
    <section class="home-identity" aria-labelledby="identity-title">
      <SectionMarker id="identity-title" number="01" name="IDENTITY" tone="pink" />
      <HeroSection site={site} />
    </section>

    <WritingSurface posts={posts} />

    <ActivityEvidence thread={currentThread} posts={posts} site={site} />

    <PersonalityContact marginalia={marginalia} />
  </main>
</BaseLayout>

<style>
  .home-page {
    display: grid;
    gap: 56px;
    width: min(1400px, calc(100% - 80px));
    margin: 0 auto;
    padding: var(--s-8) 0 var(--s-20);
  }

  .home-identity {
    display: grid;
    gap: var(--s-4);
  }

  @media (max-width: 1060px) {
    .home-page {
      width: min(100% - 32px, 760px);
      gap: var(--s-12);
    }
  }

  @media (max-width: 560px) {
    .home-page {
      width: min(100% - 28px, 1400px);
      gap: var(--s-10);
      padding-top: var(--s-6);
    }
  }
</style>
