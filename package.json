{
  "name": "enderjones-new-blog",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "build": "node scripts/validate-content.mjs && astro check && astro build && node scripts/verify-build.mjs",
    "audit:old-blog": "node scripts/audit-old-blog.mjs",
    "release:check": "npm run build && npm run audit:old-blog",
    "preview": "astro preview --host 0.0.0.0",
    "astro": "astro"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^5.0.5",
    "@rollup/plugin-yaml": "^4.1.2",
    "@types/node": "^25.8.0",
    "astro": "^6.3.2",
    "katex": "^0.16.46",
    "rehype-katex": "^7.0.1",
    "remark-directive": "^4.0.0",
    "remark-math": "^6.0.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "yaml": "^2.9.0"
  }
}
